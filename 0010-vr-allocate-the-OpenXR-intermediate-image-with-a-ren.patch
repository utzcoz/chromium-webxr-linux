From 1cbb252e7a60f64ceaeb15fb8541f3d14cbdb9b5 Mon Sep 17 00:00:00 2001
From: utzcoz <utzcoz@outlook.com>
Date: Sun, 12 Jul 2026 18:07:46 +0800
Subject: [PATCH 10/10] vr: allocate the OpenXR intermediate image with a
 renderable DRM modifier on NVIDIA (Linux)

The WebXR frame-sharing path exports the intermediate VkImage as a LINEAR (modifier 0) DMA-BUF
for the GPU process to render WebGL into. NVIDIA's GL/EGL cannot render into a LINEAR DMA-BUF
import (WebGL reports GL_FRAMEBUFFER_INCOMPLETE_ATTACHMENT), so immersive-vr only rendered with
--use-angle=vulkan.

On NVIDIA (vendorID 0x10DE), allocate the intermediate image with a driver-chosen renderable,
single-plane, non-linear DRM format modifier via VK_EXT_image_drm_format_modifier and pass it
through the NativePixmapHandle. Fall back to LINEAR if the extension is unavailable, no
qualifying modifier exists, or allocation fails. Every other vendor keeps the LINEAR path
byte-for-byte unchanged.

Setting WEBXR_OPENXR_FORCE_RENDERABLE_MODIFIER=1 forces the modifier path on any GPU, so it can
be exercised on non-NVIDIA hardware for verification.
---
 .../linux/openxr_graphics_binding_vulkan.cc   | 330 +++++++++++++++++-
 .../linux/openxr_graphics_binding_vulkan.h    |  38 +-
 2 files changed, 363 insertions(+), 5 deletions(-)

diff --git a/device/vr/openxr/linux/openxr_graphics_binding_vulkan.cc b/device/vr/openxr/linux/openxr_graphics_binding_vulkan.cc
index daef5a1843faf..a2d223d592e8b 100644
--- a/device/vr/openxr/linux/openxr_graphics_binding_vulkan.cc
+++ b/device/vr/openxr/linux/openxr_graphics_binding_vulkan.cc
@@ -13,6 +13,7 @@
 
 #include "base/command_line.h"
 #include "base/compiler_specific.h"
+#include "base/environment.h"
 #include "base/containers/span.h"
 #include "base/files/scoped_file.h"
 #include "base/logging.h"
@@ -38,6 +39,12 @@ namespace device {
 
 namespace {
 
+// PCI vendor ID for NVIDIA. NVIDIA's GL/EGL stack cannot render into a LINEAR
+// (modifier 0) DMA-BUF import, so the intermediate image is allocated with a
+// renderable non-linear DRM format modifier on this vendor. See
+// CreateIntermediateImage.
+constexpr uint32_t kVendorIdNvidia = 0x10DE;
+
 // SPIR-V for the overlay composite pass, compiled offline with glslc -O
 // (shaderc). GLSL sources are inlined below each array.
 //
@@ -352,8 +359,10 @@ bool OpenXrGraphicsBindingVulkan::Initialize(XrInstance instance,
     max_texture_size_ =
         gfx::Size(static_cast<int>(props.limits.maxImageDimension2D),
                   static_cast<int>(props.limits.maxImageDimension2D));
+    gpu_vendor_id_ = props.vendorID;
     DVLOG(1) << __func__ << " maxImageDimension2D="
-             << props.limits.maxImageDimension2D;
+             << props.limits.maxImageDimension2D << " vendorID=0x" << std::hex
+             << props.vendorID << std::dec;
   }
 
   // --- Step 6: Find a graphics-capable queue family -------------------------
@@ -434,6 +443,10 @@ bool OpenXrGraphicsBindingVulkan::Initialize(XrInstance instance,
       MaybeAdd(VK_KHR_EXTERNAL_SEMAPHORE_FD_EXTENSION_NAME);
   MaybeAdd(VK_KHR_EXTERNAL_FENCE_EXTENSION_NAME);
   MaybeAdd(VK_KHR_EXTERNAL_FENCE_FD_EXTENSION_NAME);
+  // Needed for the NVIDIA renderable-modifier intermediate-image path
+  // (VK_IMAGE_TILING_DRM_FORMAT_MODIFIER_EXT). Its dependency
+  // VK_KHR_image_format_list is requested above. Absent -> that path is skipped.
+  has_drm_format_modifier_ = MaybeAdd("VK_EXT_image_drm_format_modifier");
 
   float queue_priority = 1.0f;
   VkDeviceQueueCreateInfo queue_ci{};
@@ -647,6 +660,36 @@ bool OpenXrGraphicsBindingVulkan::CreateIntermediateImage(
     VkFormat format,
     VkImageUsageFlags usage,
     IntermediateImage* out_image) {
+  // NVIDIA's GL/EGL cannot render into a LINEAR DMA-BUF import (WebGL reports a
+  // GL_FRAMEBUFFER_INCOMPLETE_ATTACHMENT), so on NVIDIA allocate the image with
+  // a driver-chosen renderable non-linear DRM modifier instead. Every other
+  // vendor keeps the LINEAR path, byte-for-byte unchanged.
+  //
+  // WEBXR_OPENXR_FORCE_RENDERABLE_MODIFIER=1 forces the modifier path on any
+  // GPU. This is a verification aid: it exercises the modifier path end-to-end
+  // on non-NVIDIA hardware (e.g. AMD, whose GL renders its own modifiers), which
+  // is otherwise impossible without NVIDIA hardware.
+  static const bool force_modifier =
+      base::Environment::Create()->HasVar(
+          "WEBXR_OPENXR_FORCE_RENDERABLE_MODIFIER");
+  const bool use_modifier_path =
+      has_drm_format_modifier_ &&
+      (gpu_vendor_id_ == kVendorIdNvidia || force_modifier);
+  if (use_modifier_path) {
+    if (CreateIntermediateImageWithModifier(size, format, usage, out_image)) {
+      return true;
+    }
+    DVLOG(1) << "CreateIntermediateImage: renderable-modifier path failed; "
+                "falling back to LINEAR";
+  }
+  return CreateIntermediateImageLinear(size, format, usage, out_image);
+}
+
+bool OpenXrGraphicsBindingVulkan::CreateIntermediateImageLinear(
+    const gfx::Size& size,
+    VkFormat format,
+    VkImageUsageFlags usage,
+    IntermediateImage* out_image) {
   CHECK(vk_get_device_proc_addr_);
   CHECK(vk_device_ != VK_NULL_HANDLE);
 
@@ -793,6 +836,283 @@ bool OpenXrGraphicsBindingVulkan::CreateIntermediateImage(
   out_image->stride = static_cast<uint32_t>(layout.rowPitch);
   out_image->offset = static_cast<uint32_t>(layout.offset);
   out_image->allocation_size = layout.size;
+  out_image->modifier = 0;  // DRM_FORMAT_MOD_LINEAR
+  return true;
+}
+
+bool OpenXrGraphicsBindingVulkan::CreateIntermediateImageWithModifier(
+    const gfx::Size& size,
+    VkFormat format,
+    VkImageUsageFlags usage,
+    IntermediateImage* out_image) {
+  CHECK(vk_get_device_proc_addr_);
+  CHECK(vk_device_ != VK_NULL_HANDLE);
+  DCHECK(has_drm_format_modifier_);
+
+  auto pfn_create_image = reinterpret_cast<PFN_vkCreateImage>(
+      vk_get_device_proc_addr_(vk_device_, "vkCreateImage"));
+  auto pfn_get_memory_reqs = reinterpret_cast<PFN_vkGetImageMemoryRequirements>(
+      vk_get_device_proc_addr_(vk_device_, "vkGetImageMemoryRequirements"));
+  auto pfn_allocate_memory = reinterpret_cast<PFN_vkAllocateMemory>(
+      vk_get_device_proc_addr_(vk_device_, "vkAllocateMemory"));
+  auto pfn_bind_image_memory = reinterpret_cast<PFN_vkBindImageMemory>(
+      vk_get_device_proc_addr_(vk_device_, "vkBindImageMemory"));
+  auto pfn_get_physical_device_memory_properties =
+      reinterpret_cast<PFN_vkGetPhysicalDeviceMemoryProperties>(
+          vk_get_instance_proc_addr_(vk_instance_,
+                                     "vkGetPhysicalDeviceMemoryProperties"));
+  auto pfn_get_format_props2 =
+      reinterpret_cast<PFN_vkGetPhysicalDeviceFormatProperties2>(
+          vk_get_instance_proc_addr_(vk_instance_,
+                                     "vkGetPhysicalDeviceFormatProperties2"));
+  if (!pfn_get_format_props2) {
+    // Fall back to the KHR alias (VK_KHR_get_physical_device_properties2 is
+    // enabled at instance creation) for 1.0 instances.
+    pfn_get_format_props2 =
+        reinterpret_cast<PFN_vkGetPhysicalDeviceFormatProperties2>(
+            vk_get_instance_proc_addr_(
+                vk_instance_, "vkGetPhysicalDeviceFormatProperties2KHR"));
+  }
+  auto pfn_get_image_format_props2 =
+      reinterpret_cast<PFN_vkGetPhysicalDeviceImageFormatProperties2>(
+          vk_get_instance_proc_addr_(
+              vk_instance_, "vkGetPhysicalDeviceImageFormatProperties2"));
+  if (!pfn_get_image_format_props2) {
+    pfn_get_image_format_props2 =
+        reinterpret_cast<PFN_vkGetPhysicalDeviceImageFormatProperties2>(
+            vk_get_instance_proc_addr_(
+                vk_instance_, "vkGetPhysicalDeviceImageFormatProperties2KHR"));
+  }
+  auto pfn_get_modifier_props =
+      reinterpret_cast<PFN_vkGetImageDrmFormatModifierPropertiesEXT>(
+          vk_get_device_proc_addr_(vk_device_,
+                                   "vkGetImageDrmFormatModifierPropertiesEXT"));
+  auto pfn_get_image_subresource_layout =
+      reinterpret_cast<PFN_vkGetImageSubresourceLayout>(
+          vk_get_device_proc_addr_(vk_device_, "vkGetImageSubresourceLayout"));
+  auto pfn_destroy_image = reinterpret_cast<PFN_vkDestroyImage>(
+      vk_get_device_proc_addr_(vk_device_, "vkDestroyImage"));
+  auto pfn_free_memory = reinterpret_cast<PFN_vkFreeMemory>(
+      vk_get_device_proc_addr_(vk_device_, "vkFreeMemory"));
+
+  if (!pfn_create_image || !pfn_get_memory_reqs || !pfn_allocate_memory ||
+      !pfn_bind_image_memory || !pfn_get_physical_device_memory_properties ||
+      !pfn_get_format_props2 || !pfn_get_modifier_props ||
+      !pfn_get_image_subresource_layout || !pfn_destroy_image ||
+      !pfn_free_memory) {
+    DVLOG(1) << "CreateIntermediateImageWithModifier: missing Vulkan functions";
+    return false;
+  }
+
+  // Collect candidate modifiers: renderable (color attachment + transfer),
+  // single-plane, and non-linear (LINEAR is exactly what fails on NVIDIA GL).
+  constexpr VkFormatFeatureFlags kRequiredFeatures =
+      VK_FORMAT_FEATURE_COLOR_ATTACHMENT_BIT |
+      VK_FORMAT_FEATURE_TRANSFER_SRC_BIT | VK_FORMAT_FEATURE_TRANSFER_DST_BIT;
+
+  VkDrmFormatModifierPropertiesListEXT modifier_list{};
+  modifier_list.sType =
+      VK_STRUCTURE_TYPE_DRM_FORMAT_MODIFIER_PROPERTIES_LIST_EXT;
+  VkFormatProperties2 format_props2{};
+  format_props2.sType = VK_STRUCTURE_TYPE_FORMAT_PROPERTIES_2;
+  format_props2.pNext = &modifier_list;
+  // First call: get the count.
+  pfn_get_format_props2(binding_.physicalDevice, format, &format_props2);
+  if (modifier_list.drmFormatModifierCount == 0) {
+    DVLOG(1) << "CreateIntermediateImageWithModifier: driver reports no DRM "
+                "modifiers for format "
+             << format;
+    return false;
+  }
+  std::vector<VkDrmFormatModifierPropertiesEXT> modifier_props(
+      modifier_list.drmFormatModifierCount);
+  modifier_list.pDrmFormatModifierProperties = modifier_props.data();
+  // Second call: fill the list.
+  pfn_get_format_props2(binding_.physicalDevice, format, &format_props2);
+
+  std::vector<uint64_t> candidates;
+  for (const auto& mp : modifier_props) {
+    if (mp.drmFormatModifier == 0 /* DRM_FORMAT_MOD_LINEAR */) {
+      continue;
+    }
+    if (mp.drmFormatModifierPlaneCount != 1) {
+      continue;
+    }
+    if ((mp.drmFormatModifierTilingFeatures & kRequiredFeatures) !=
+        kRequiredFeatures) {
+      continue;
+    }
+    candidates.push_back(mp.drmFormatModifier);
+  }
+  if (candidates.empty()) {
+    DVLOG(1) << "CreateIntermediateImageWithModifier: no renderable "
+                "single-plane non-linear modifier for format "
+             << format;
+    return false;
+  }
+
+  // Validate each candidate against the actual usage and DMA-BUF export before
+  // offering it. A modifier appearing in the format's tiling-feature list is
+  // not guaranteed to be valid for this image's usage *combined with* external
+  // DMA-BUF export; vkCreateImage may still accept it and produce a buffer that
+  // faults the GPU once rendered into and shared across processes (observed as
+  // VK_ERROR_DEVICE_LOST on NVIDIA). Keep only modifiers the driver confirms
+  // support the usage and are exportable as a DMA-BUF.
+  if (pfn_get_image_format_props2) {
+    std::vector<uint64_t> validated;
+    for (uint64_t mod : candidates) {
+      VkPhysicalDeviceExternalImageFormatInfo ext_fmt_info{};
+      ext_fmt_info.sType =
+          VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_EXTERNAL_IMAGE_FORMAT_INFO;
+      ext_fmt_info.handleType = VK_EXTERNAL_MEMORY_HANDLE_TYPE_DMA_BUF_BIT_EXT;
+
+      VkPhysicalDeviceImageDrmFormatModifierInfoEXT drm_info{};
+      drm_info.sType =
+          VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_IMAGE_DRM_FORMAT_MODIFIER_INFO_EXT;
+      drm_info.pNext = &ext_fmt_info;
+      drm_info.drmFormatModifier = mod;
+      drm_info.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+
+      VkPhysicalDeviceImageFormatInfo2 fmt_info{};
+      fmt_info.sType = VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_IMAGE_FORMAT_INFO_2;
+      fmt_info.pNext = &drm_info;
+      fmt_info.format = format;
+      fmt_info.type = VK_IMAGE_TYPE_2D;
+      fmt_info.tiling = VK_IMAGE_TILING_DRM_FORMAT_MODIFIER_EXT;
+      fmt_info.usage = usage;
+
+      VkExternalImageFormatProperties ext_props{};
+      ext_props.sType = VK_STRUCTURE_TYPE_EXTERNAL_IMAGE_FORMAT_PROPERTIES;
+      VkImageFormatProperties2 props2{};
+      props2.sType = VK_STRUCTURE_TYPE_IMAGE_FORMAT_PROPERTIES_2;
+      props2.pNext = &ext_props;
+
+      if (pfn_get_image_format_props2(binding_.physicalDevice, &fmt_info,
+                                      &props2) == VK_SUCCESS &&
+          (ext_props.externalMemoryProperties.externalMemoryFeatures &
+           VK_EXTERNAL_MEMORY_FEATURE_EXPORTABLE_BIT)) {
+        validated.push_back(mod);
+      }
+    }
+    candidates.swap(validated);
+    if (candidates.empty()) {
+      DVLOG(1) << "CreateIntermediateImageWithModifier: no modifier is valid "
+                  "for external DMA-BUF export with the requested usage";
+      return false;
+    }
+  }
+
+  // Create the image with DRM-modifier tiling, offering the candidate list; the
+  // driver picks one it can allocate.
+  VkExternalMemoryImageCreateInfo external_image_info{};
+  external_image_info.sType =
+      VK_STRUCTURE_TYPE_EXTERNAL_MEMORY_IMAGE_CREATE_INFO;
+  external_image_info.handleTypes =
+      VK_EXTERNAL_MEMORY_HANDLE_TYPE_DMA_BUF_BIT_EXT;
+
+  VkImageDrmFormatModifierListCreateInfoEXT modifier_list_ci{};
+  modifier_list_ci.sType =
+      VK_STRUCTURE_TYPE_IMAGE_DRM_FORMAT_MODIFIER_LIST_CREATE_INFO_EXT;
+  modifier_list_ci.pNext = &external_image_info;
+  modifier_list_ci.drmFormatModifierCount =
+      static_cast<uint32_t>(candidates.size());
+  modifier_list_ci.pDrmFormatModifiers = candidates.data();
+
+  VkImageCreateInfo image_ci{};
+  image_ci.sType = VK_STRUCTURE_TYPE_IMAGE_CREATE_INFO;
+  image_ci.pNext = &modifier_list_ci;
+  image_ci.imageType = VK_IMAGE_TYPE_2D;
+  image_ci.format = format;
+  image_ci.extent = {static_cast<uint32_t>(size.width()),
+                     static_cast<uint32_t>(size.height()), 1};
+  image_ci.mipLevels = 1;
+  image_ci.arrayLayers = 1;
+  image_ci.samples = VK_SAMPLE_COUNT_1_BIT;
+  image_ci.tiling = VK_IMAGE_TILING_DRM_FORMAT_MODIFIER_EXT;
+  image_ci.usage = usage;
+  image_ci.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+  image_ci.initialLayout = VK_IMAGE_LAYOUT_UNDEFINED;
+
+  VkImage image = VK_NULL_HANDLE;
+  if (pfn_create_image(vk_device_, &image_ci, nullptr, &image) != VK_SUCCESS) {
+    DVLOG(1) << "CreateIntermediateImageWithModifier: vkCreateImage failed";
+    return false;
+  }
+
+  // Query which modifier the driver actually chose.
+  VkImageDrmFormatModifierPropertiesEXT chosen{};
+  chosen.sType = VK_STRUCTURE_TYPE_IMAGE_DRM_FORMAT_MODIFIER_PROPERTIES_EXT;
+  if (pfn_get_modifier_props(vk_device_, image, &chosen) != VK_SUCCESS) {
+    DVLOG(1) << "CreateIntermediateImageWithModifier: "
+                "vkGetImageDrmFormatModifierPropertiesEXT failed";
+    pfn_destroy_image(vk_device_, image, nullptr);
+    return false;
+  }
+
+  VkMemoryRequirements mem_reqs{};
+  pfn_get_memory_reqs(vk_device_, image, &mem_reqs);
+
+  VkPhysicalDeviceMemoryProperties mem_props{};
+  pfn_get_physical_device_memory_properties(binding_.physicalDevice,
+                                            &mem_props);
+  uint32_t memory_type_index = UINT32_MAX;
+  for (uint32_t i = 0; i < mem_props.memoryTypeCount; ++i) {
+    if ((mem_reqs.memoryTypeBits & (1u << i)) &&
+        (UNSAFE_TODO(mem_props.memoryTypes[i]).propertyFlags &
+         VK_MEMORY_PROPERTY_DEVICE_LOCAL_BIT)) {
+      memory_type_index = i;
+      break;
+    }
+  }
+  if (memory_type_index == UINT32_MAX) {
+    DVLOG(1) << "CreateIntermediateImageWithModifier: no device-local memory";
+    pfn_destroy_image(vk_device_, image, nullptr);
+    return false;
+  }
+
+  VkExportMemoryAllocateInfo export_alloc_info{};
+  export_alloc_info.sType = VK_STRUCTURE_TYPE_EXPORT_MEMORY_ALLOCATE_INFO;
+  export_alloc_info.handleTypes =
+      VK_EXTERNAL_MEMORY_HANDLE_TYPE_DMA_BUF_BIT_EXT;
+
+  VkMemoryAllocateInfo alloc_info{};
+  alloc_info.sType = VK_STRUCTURE_TYPE_MEMORY_ALLOCATE_INFO;
+  alloc_info.pNext = &export_alloc_info;
+  alloc_info.allocationSize = mem_reqs.size;
+  alloc_info.memoryTypeIndex = memory_type_index;
+
+  VkDeviceMemory memory = VK_NULL_HANDLE;
+  if (pfn_allocate_memory(vk_device_, &alloc_info, nullptr, &memory) !=
+      VK_SUCCESS) {
+    DVLOG(1) << "CreateIntermediateImageWithModifier: vkAllocateMemory failed";
+    pfn_destroy_image(vk_device_, image, nullptr);
+    return false;
+  }
+  if (pfn_bind_image_memory(vk_device_, image, memory, 0) != VK_SUCCESS) {
+    DVLOG(1) << "CreateIntermediateImageWithModifier: vkBindImageMemory failed";
+    pfn_destroy_image(vk_device_, image, nullptr);
+    pfn_free_memory(vk_device_, memory, nullptr);
+    return false;
+  }
+
+  // Read back the single plane's layout for the chosen modifier.
+  VkImageSubresource subresource{};
+  subresource.aspectMask = VK_IMAGE_ASPECT_MEMORY_PLANE_0_BIT_EXT;
+  subresource.mipLevel = 0;
+  subresource.arrayLayer = 0;
+  VkSubresourceLayout layout{};
+  pfn_get_image_subresource_layout(vk_device_, image, &subresource, &layout);
+
+  out_image->image = image;
+  out_image->memory = memory;
+  out_image->stride = static_cast<uint32_t>(layout.rowPitch);
+  out_image->offset = static_cast<uint32_t>(layout.offset);
+  out_image->allocation_size = mem_reqs.size;
+  out_image->modifier = chosen.drmFormatModifier;
+  DVLOG(1) << "CreateIntermediateImageWithModifier: chose modifier 0x"
+           << std::hex << chosen.drmFormatModifier << std::dec
+           << " stride=" << out_image->stride
+           << " offset=" << out_image->offset;
   return true;
 }
 
@@ -1012,9 +1332,13 @@ void OpenXrGraphicsBindingVulkan::CreateSharedImages(
       return;
     }
 
-    // Wrap the DMA-BUF FD with proper stride from VkSubresourceLayout.
+    // Wrap the DMA-BUF FD with the stride/offset from VkSubresourceLayout and
+    // the DRM modifier the image was actually allocated with (0 == LINEAR on
+    // the default path; a renderable non-linear modifier on the NVIDIA path).
+    DVLOG(1) << "CreateSharedImages: slot " << i << " modifier=0x" << std::hex
+             << intermediate_images_[i].modifier << std::dec;
     gfx::NativePixmapHandle pixmap_handle;
-    pixmap_handle.modifier = 0;  // DRM_FORMAT_MOD_LINEAR
+    pixmap_handle.modifier = intermediate_images_[i].modifier;
     pixmap_handle.planes.emplace_back(
         /*stride=*/intermediate_images_[i].stride,
         /*offset=*/intermediate_images_[i].offset,
diff --git a/device/vr/openxr/linux/openxr_graphics_binding_vulkan.h b/device/vr/openxr/linux/openxr_graphics_binding_vulkan.h
index 2d567f27b7a23..3f6d1ddfacd64 100644
--- a/device/vr/openxr/linux/openxr_graphics_binding_vulkan.h
+++ b/device/vr/openxr/linux/openxr_graphics_binding_vulkan.h
@@ -83,6 +83,10 @@ class DEVICE_VR_EXPORT OpenXrGraphicsBindingVulkan
     uint32_t stride = 0;       // Row pitch from VkSubresourceLayout
     uint32_t offset = 0;       // Plane offset
     uint64_t allocation_size = 0;  // Total allocation size
+    // DRM format modifier for the exported DMA-BUF. 0 == DRM_FORMAT_MOD_LINEAR
+    // (the default path). Set to a driver-chosen renderable modifier on the
+    // NVIDIA modifier path (see CreateIntermediateImageWithModifier).
+    uint64_t modifier = 0;
     // Tracks the current Vulkan image layout so RenderLayer can supply the
     // correct oldLayout in pipeline barriers across frames.
     VkImageLayout current_layout = VK_IMAGE_LAYOUT_UNDEFINED;
@@ -94,13 +98,33 @@ class DEVICE_VR_EXPORT OpenXrGraphicsBindingVulkan
   // Cleans up the command pool and command buffer.
   void DestroyCommandPool();
 
-  // Creates a single exportable (LINEAR, DMA-BUF) VkImage + VkDeviceMemory
-  // pair with the given image usage flags.
+  // Creates a single exportable (DMA-BUF) VkImage + VkDeviceMemory pair with the
+  // given image usage flags. Dispatches to the modifier path on NVIDIA (whose
+  // GL/EGL cannot render into a LINEAR DMA-BUF import) and the LINEAR path
+  // everywhere else, falling back to LINEAR if the modifier path fails.
   bool CreateIntermediateImage(const gfx::Size& size,
                                VkFormat format,
                                VkImageUsageFlags usage,
                                IntermediateImage* out_image);
 
+  // The default path: a LINEAR-tiled (modifier 0) exportable image. Unchanged
+  // behavior for all non-NVIDIA GPUs.
+  bool CreateIntermediateImageLinear(const gfx::Size& size,
+                                     VkFormat format,
+                                     VkImageUsageFlags usage,
+                                     IntermediateImage* out_image);
+
+  // The NVIDIA path: allocates the image with a driver-chosen renderable,
+  // non-linear, single-plane DRM format modifier (via
+  // VK_EXT_image_drm_format_modifier) so the GPU-process GL import is
+  // framebuffer-renderable. Returns false (and the caller falls back to LINEAR)
+  // if the extension is unavailable, no qualifying modifier exists, or any
+  // Vulkan call fails.
+  bool CreateIntermediateImageWithModifier(const gfx::Size& size,
+                                           VkFormat format,
+                                           VkImageUsageFlags usage,
+                                           IntermediateImage* out_image);
+
   // Destroys all intermediate images and frees their Vulkan memory.
   void DestroyIntermediateImages();
 
@@ -174,6 +198,16 @@ class DEVICE_VR_EXPORT OpenXrGraphicsBindingVulkan
   // creation.
   bool has_external_semaphore_fd_ = false;
 
+  // True if VK_EXT_image_drm_format_modifier was enabled at VkDevice creation.
+  // Required for the NVIDIA renderable-modifier intermediate-image path.
+  bool has_drm_format_modifier_ = false;
+
+  // VkPhysicalDeviceProperties.vendorID of the device the OpenXR runtime chose,
+  // cached at Initialize(). Used to select the intermediate-image allocation
+  // path (NVIDIA needs a non-linear renderable DRM modifier; see
+  // CreateIntermediateImage).
+  uint32_t gpu_vendor_id_ = 0;
+
   // Queue, command pool, command buffer, and submit fence for RenderLayer blits.
   VkQueue vk_queue_ = VK_NULL_HANDLE;
   VkCommandPool vk_command_pool_ = VK_NULL_HANDLE;
-- 
