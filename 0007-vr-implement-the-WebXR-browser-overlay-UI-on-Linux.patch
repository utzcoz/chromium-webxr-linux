+  pre_barriers[0] = {VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER};
+  pre_barriers[0].srcAccessMask = 0;
+  pre_barriers[0].dstAccessMask = VK_ACCESS_SHADER_READ_BIT;
+  pre_barriers[0].oldLayout = overlay_layout_;
+  pre_barriers[0].newLayout = VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL;
+  pre_barriers[0].srcQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+  pre_barriers[0].dstQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+  pre_barriers[0].image = overlay_owned_image_.image;
+  pre_barriers[0].subresourceRange = {VK_IMAGE_ASPECT_COLOR_BIT, 0, 1, 0, 1};
+  pre_barriers[1] = {VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER};
+  pre_barriers[1].srcAccessMask = VK_ACCESS_TRANSFER_WRITE_BIT;
+  pre_barriers[1].dstAccessMask = VK_ACCESS_COLOR_ATTACHMENT_READ_BIT |
+                                  VK_ACCESS_COLOR_ATTACHMENT_WRITE_BIT;
+  pre_barriers[1].oldLayout = VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL;
+  pre_barriers[1].newLayout = VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL;
+  pre_barriers[1].srcQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+  pre_barriers[1].dstQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+  pre_barriers[1].image = dst;
+  pre_barriers[1].subresourceRange = {VK_IMAGE_ASPECT_COLOR_BIT, 0, 1, 0, 1};
+  pfn_cmd_pipeline_barrier(cb, VK_PIPELINE_STAGE_TRANSFER_BIT,
+                           VK_PIPELINE_STAGE_FRAGMENT_SHADER_BIT |
+                               VK_PIPELINE_STAGE_COLOR_ATTACHMENT_OUTPUT_BIT,
+                           0, 0, nullptr, 0, nullptr, 2, pre_barriers);
+
+  VkRenderPassBeginInfo rp_begin{VK_STRUCTURE_TYPE_RENDER_PASS_BEGIN_INFO};
+  rp_begin.renderPass = overlay_render_pass_;
+  rp_begin.framebuffer = it->second.framebuffer;
+  rp_begin.renderArea = {{0, 0},
+                         {static_cast<uint32_t>(swapchain_size.width()),
+                          static_cast<uint32_t>(swapchain_size.height())}};
+  pfn_cmd_begin_render_pass(cb, &rp_begin, VK_SUBPASS_CONTENTS_INLINE);
+  pfn_cmd_bind_pipeline(cb, VK_PIPELINE_BIND_POINT_GRAPHICS,
+                        overlay_pipeline_);
+  pfn_cmd_bind_descriptor_sets(cb, VK_PIPELINE_BIND_POINT_GRAPHICS,
+                               overlay_pipeline_layout_, 0, 1,
+                               &overlay_descriptor_set_, 0, nullptr);
+
+  // One fullscreen-triangle draw per eye: the viewport/scissor select the
+  // eye's half of the side-by-side swapchain image, and the push constants
+  // select that eye's UV sub-rect of the overlay texture. The UV is passed
+  // straight through with NO y-flip: the browser rendered the overlay with
+  // GL's bottom-up row order, and the swapchain content is bottom-up too
+  // (ShouldFlipSubmittedImage() is true, so GetProjectionViews() negates
+  // fov.angleUp/angleDown and the runtime un-flips the whole image at
+  // composition time). Pre-flipping the overlay here would make the runtime's
+  // flip show it upside-down.
+  const int eye_width = swapchain_size.width() / 2;
+  const int height = swapchain_size.height();
+  const struct {
+    int x;
+    gfx::RectF uv;
+  } eyes[2] = {{0, overlay_left_uv_}, {eye_width, overlay_right_uv_}};
+  for (const auto& eye : eyes) {
+    VkViewport viewport{static_cast<float>(eye.x),
+                        0.0f,
+                        static_cast<float>(eye_width),
+                        static_cast<float>(height),
+                        0.0f,
+                        1.0f};
+    pfn_cmd_set_viewport(cb, 0, 1, &viewport);
+    VkRect2D scissor{{eye.x, 0},
+                     {static_cast<uint32_t>(eye_width),
+                      static_cast<uint32_t>(height)}};
+    pfn_cmd_set_scissor(cb, 0, 1, &scissor);
+    const float uv_rect[4] = {eye.uv.x(), eye.uv.y(), eye.uv.width(),
+                              eye.uv.height()};
+    pfn_cmd_push_constants(cb, overlay_pipeline_layout_,
+                           VK_SHADER_STAGE_FRAGMENT_BIT, 0, sizeof(uv_rect),
+                           uv_rect);
+    pfn_cmd_draw(cb, 3, 1, 0, 0);
+  }
+  pfn_cmd_end_render_pass(cb);
+
+  // Restore the overlay to GENERAL so the next browser-side write (GL via
+  // DMA-BUF, or the staging-buffer upload) sees a well-defined layout.
+  VkImageMemoryBarrier post_barrier{VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER};
+  post_barrier.srcAccessMask = VK_ACCESS_SHADER_READ_BIT;
+  post_barrier.dstAccessMask = 0;
+  post_barrier.oldLayout = VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL;
+  post_barrier.newLayout = VK_IMAGE_LAYOUT_GENERAL;
+  post_barrier.srcQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+  post_barrier.dstQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+  post_barrier.image = overlay_owned_image_.image;
+  post_barrier.subresourceRange = {VK_IMAGE_ASPECT_COLOR_BIT, 0, 1, 0, 1};
+  pfn_cmd_pipeline_barrier(cb, VK_PIPELINE_STAGE_FRAGMENT_SHADER_BIT,
+                           VK_PIPELINE_STAGE_BOTTOM_OF_PIPE_BIT, 0, 0, nullptr,
+                           0, nullptr, 1, &post_barrier);
+  overlay_layout_ = VK_IMAGE_LAYOUT_GENERAL;
+  return true;
+}
