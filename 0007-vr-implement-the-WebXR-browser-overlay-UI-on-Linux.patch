diff --git a/chrome/browser/vr/graphics_delegate_linux.cc b/chrome/browser/vr/graphics_delegate_linux.cc
new file mode 100644
index 0000000000000..aa717da235833
--- /dev/null
+++ b/chrome/browser/vr/graphics_delegate_linux.cc
@@ -0,0 +1,183 @@
+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/vr/graphics_delegate_linux.h"
+
+#include "base/logging.h"
+#include "content/public/browser/gpu_utils.h"
+#include "content/public/common/gpu_stream_constants.h"
+#include "gpu/command_buffer/client/client_shared_image.h"
+#include "gpu/command_buffer/client/gles2_interface.h"
+#include "gpu/command_buffer/client/gles2_lib.h"
+#include "gpu/command_buffer/client/shared_image_interface.h"
+#include "gpu/command_buffer/common/context_creation_attribs.h"
+#include "mojo/public/cpp/bindings/sync_call_restrictions.h"
+#include "url/gurl.h"
+
+namespace vr {
+
+GraphicsDelegateLinux::GraphicsDelegateLinux() = default;
+GraphicsDelegateLinux::~GraphicsDelegateLinux() = default;
+
+void GraphicsDelegateLinux::Initialize(base::OnceClosure on_initialized) {
+  gpu::GpuChannelEstablishFactory* factory =
+      content::GetGpuChannelEstablishFactory();
+  gpu_channel_host_ = factory->EstablishGpuChannelSync();
+  if (!gpu_channel_host_) {
+    LOG(ERROR) << __func__ << ": EstablishGpuChannelSync returned null; "
+               << "overlay UI cannot render.";
+    std::move(on_initialized).Run();
+    return;
+  }
+
+  context_provider_ = viz::ContextProviderCommandBuffer::CreateForGL(
+      gpu_channel_host_, content::kGpuStreamIdDefault,
+      content::kGpuStreamPriorityUI, GURL("chrome://gpu/VrUiLinux"),
+      viz::command_buffer_metrics::ContextType::XR_COMPOSITING);
+
+  gpu::ContextResult result = context_provider_->BindToCurrentSequence();
+  if (result == gpu::ContextResult::kSuccess) {
+    gl_ = context_provider_->ContextGL();
+    sii_ = context_provider_->SharedImageInterface();
+  } else {
+    LOG(ERROR) << __func__
+               << ": ContextProviderCommandBuffer::BindToCurrentSequence "
+                  "failed, result="
+               << static_cast<int>(result)
+               << "; overlay UI cannot render.";
+  }
+
+  std::move(on_initialized).Run();
+}
+
+bool GraphicsDelegateLinux::BindContext() {
+  if (!gl_)
+    return false;
+
+  // Allocate the gles2_lib thread-local key once. The VR UI shaders dispatch gl*
+  // through gles2_lib, whose key is otherwise allocated only by the VR test
+  // suite's gles2::Initialize(). Linux is the first production user, so do it
+  // here before SetGLContext()/the first shader.
+  static const bool gles2_lib_initialized = [] {
+    gles2::Initialize();
+    return true;
+  }();
+  (void)gles2_lib_initialized;
+
+  gles2::SetGLContext(gl_);
+  return true;
+}
+
+void GraphicsDelegateLinux::ClearContext() {
+  gles2::SetGLContext(nullptr);
+}
+
+bool GraphicsDelegateLinux::PreRender() {
+  if (!gl_)
+    return false;
+
+  BindContext();
+
+  // Point client_shared_image_ at the runtime-allocated overlay image.
+  if (!EnsureMemoryBuffer()) {
+    return false;
+  }
+
+  // Create a texture id and associate it with the shared image.
+  shared_image_texture_ = client_shared_image_->CreateGLTexture(gl_);
+  scoped_shared_image_access_ =
+      shared_image_texture_->BeginAccess(gpu::SyncToken(), /*readonly=*/false);
+
+  gl_->BindTexture(GL_TEXTURE_2D, scoped_shared_image_access_->texture_id());
+  gl_->TexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MAG_FILTER, GL_NEAREST);
+  gl_->TexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MIN_FILTER, GL_NEAREST);
+  gl_->TexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_S, GL_CLAMP_TO_EDGE);
+  gl_->TexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_T, GL_CLAMP_TO_EDGE);
+  gl_->BindTexture(GL_TEXTURE_2D, 0);
+
+  // Bind our image/texture/memory buffer as the draw framebuffer.
+  gl_->GenFramebuffers(1, &draw_frame_buffer_);
+  gl_->BindFramebuffer(GL_DRAW_FRAMEBUFFER, draw_frame_buffer_);
+  gl_->FramebufferTexture2D(GL_DRAW_FRAMEBUFFER, GL_COLOR_ATTACHMENT0,
+                            GL_TEXTURE_2D,
+                            scoped_shared_image_access_->texture_id(), 0);
+
+  if (gl_->GetError() != GL_NO_ERROR) {
+    gpu::SharedImageTexture::ScopedAccess::EndAccess(
+        std::move(scoped_shared_image_access_));
+    shared_image_texture_.reset();
+    // Clear any remaining GL errors.
+    while (gl_->GetError() != GL_NO_ERROR) {
+    }
+    return false;
+  }
+
+  return true;
+}
+
+void GraphicsDelegateLinux::PostRender() {
+  // Unbind the drawing buffer.
+  gl_->BindFramebuffer(GL_FRAMEBUFFER, 0);
+  gl_->DeleteFramebuffers(1, &draw_frame_buffer_);
+
+  // Generate a SyncToken after GPU is done accessing the texture. The runtime
+  // process waits on it (via SubmitOverlayTexture) before compositing.
+  access_done_sync_token_ = gpu::SharedImageTexture::ScopedAccess::EndAccess(
+      std::move(scoped_shared_image_access_));
+  sii_->VerifySyncToken(access_done_sync_token_);
+  shared_image_texture_.reset();
+  gl_->BindTexture(GL_TEXTURE_2D, 0);
+  draw_frame_buffer_ = 0;
+
+  // Flush.
+  gl_->ShallowFlushCHROMIUM();
+  ClearContext();
+}
+
+gfx::GpuMemoryBufferHandle GraphicsDelegateLinux::GetTexture() {
+  // The runtime owns the overlay image; there is nothing to hand back. The
+  // (null) handle SubmitOverlayTexture receives tells it to composite its own.
+  return gfx::GpuMemoryBufferHandle();
+}
+
+gpu::SyncToken GraphicsDelegateLinux::GetSyncToken() {
+  return access_done_sync_token_;
+}
+
+void GraphicsDelegateLinux::SetOverlaySharedImage(
+    gpu::ExportedSharedImage exported_image,
+    const gpu::SyncToken& sync_token) {
+  // Import the runtime-allocated overlay image non-owningly (the runtime keeps
+  // the backing alive) for EnsureMemoryBuffer() to render into.
+  overlay_shared_image_ =
+      gpu::ClientSharedImage::ImportUnowned(std::move(exported_image));
+  overlay_creation_sync_token_ = sync_token;
+}
+
+bool GraphicsDelegateLinux::EnsureMemoryBuffer() {
+  if (!overlay_shared_image_) {
+    return false;  // Not handed one this frame; nothing to render into.
+  }
+  // Order our GL writes after the runtime's SharedImage creation. BindContext()
+  // (called by PreRender() before this) has bound gl_, so this wait is inserted
+  // on the same command stream as the following draws.
+  if (overlay_creation_sync_token_.HasData()) {
+    gl_->WaitSyncTokenCHROMIUM(overlay_creation_sync_token_.GetConstData());
+  }
+  client_shared_image_ = overlay_shared_image_;
+  return true;
+}
+
+void GraphicsDelegateLinux::ResetMemoryBuffer() {
+  // The overlay image is owned by the runtime; just drop our imported reference.
+  client_shared_image_.reset();
+  access_done_sync_token_.Clear();
+}
+
+void GraphicsDelegateLinux::ClearBufferToBlack() {
+  gl_->ClearColor(0, 0, 0, 0);
+  gl_->Clear(GL_COLOR_BUFFER_BIT);
+}
+
+}  // namespace vr
