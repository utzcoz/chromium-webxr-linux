+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_VR_GRAPHICS_DELEGATE_LINUX_H_
+#define CHROME_BROWSER_VR_GRAPHICS_DELEGATE_LINUX_H_
+
+#include "base/memory/raw_ptr.h"
+#include "base/memory/scoped_refptr.h"
+#include "chrome/browser/vr/graphics_delegate.h"
+#include "gpu/GLES2/gl2extchromium.h"
+#include "gpu/command_buffer/client/client_shared_image.h"
+#include "gpu/command_buffer/client/gles2_interface.h"
+#include "gpu/command_buffer/common/sync_token.h"
+#include "gpu/ipc/client/gpu_channel_host.h"
+#include "services/viz/public/cpp/gpu/context_provider_command_buffer.h"
+#include "ui/gfx/geometry/size.h"
+
+namespace gpu {
+class SharedImageInterface;
+struct ExportedSharedImage;
+namespace gles2 {
+class GLES2Interface;
+}
+}  // namespace gpu
+
+namespace vr {
+
+// Draws the WebXR browser overlay UI (permission prompts, capture indicators)
+// on Linux. The renderer is a plain GL-command-buffer + SharedImage pipeline
+// (mirroring GraphicsDelegateWin, which is platform-neutral despite its name).
+// What is Linux-specific: the XR runtime process allocates the overlay image and
+// hands it here via SetOverlaySharedImage(); EnsureMemoryBuffer() renders into
+// that imported image rather than allocating one, and GetTexture() returns
+// nothing because the runtime owns the backing and composites it itself. See the
+// RequestNextOverlayPose reply in isolated_xr_service.mojom for the rationale.
+class GraphicsDelegateLinux : public GraphicsDelegate {
+ public:
+  GraphicsDelegateLinux();
+  ~GraphicsDelegateLinux() override;
+
+  // GraphicsDelegate:
+  void Initialize(base::OnceClosure on_initialized) override;
+  bool PreRender() override;
+  void PostRender() override;
+  gfx::GpuMemoryBufferHandle GetTexture() override;
+  gpu::SyncToken GetSyncToken() override;
+  void ResetMemoryBuffer() override;
+  void SetOverlaySharedImage(gpu::ExportedSharedImage exported_image,
+                             const gpu::SyncToken& sync_token) override;
+  bool BindContext() override;
+  void ClearContext() override;
+
+ private:
+  void ClearBufferToBlack() override;
+
+  // Points client_shared_image_ at the runtime-allocated overlay image.
+  bool EnsureMemoryBuffer();
+
+  scoped_refptr<gpu::GpuChannelHost> gpu_channel_host_;
+  scoped_refptr<viz::ContextProviderCommandBuffer> context_provider_;
+  raw_ptr<gpu::gles2::GLES2Interface> gl_ = nullptr;
+  raw_ptr<gpu::SharedImageInterface> sii_ = nullptr;
+  scoped_refptr<gpu::ClientSharedImage> client_shared_image_;
+  std::unique_ptr<gpu::SharedImageTexture> shared_image_texture_;
+  std::unique_ptr<gpu::SharedImageTexture::ScopedAccess>
+      scoped_shared_image_access_;
+  GLuint draw_frame_buffer_ = 0;
+  // Sync point after access to the buffer is done.
+  gpu::SyncToken access_done_sync_token_;
+
+  // The runtime-allocated overlay image (imported from the ExportedSharedImage
+  // handed to SetOverlaySharedImage) that EnsureMemoryBuffer() renders into, and
+  // the sync token our GL writes must wait on before touching it. Imported
+  // non-owningly; the runtime side keeps the backing alive.
+  scoped_refptr<gpu::ClientSharedImage> overlay_shared_image_;
+  gpu::SyncToken overlay_creation_sync_token_;
+};
+
+}  // namespace vr
+
+#endif  // CHROME_BROWSER_VR_GRAPHICS_DELEGATE_LINUX_H_
