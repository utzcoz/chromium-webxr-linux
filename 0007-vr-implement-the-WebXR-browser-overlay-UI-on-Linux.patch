+      !overlay_client_shared_image_ || intermediate_images_.empty()) {
+    // No overlay image has been handed to the browser yet (or no swapchain to
+    // composite into) — nothing to show this frame.
+    has_overlay_ = false;
+    return true;
   }
 
   overlay_left_uv_ = left;
