+bool OpenXrGraphicsBindingVulkan::UpdateOverlayDescriptor() {
+  CHECK(overlay_owned_image_.image != VK_NULL_HANDLE);
+  CHECK(overlay_descriptor_set_ != VK_NULL_HANDLE);
+
+  auto pfn_create_image_view = reinterpret_cast<PFN_vkCreateImageView>(
+      vk_get_device_proc_addr_(vk_device_, "vkCreateImageView"));
+  auto pfn_destroy_image_view = reinterpret_cast<PFN_vkDestroyImageView>(
+      vk_get_device_proc_addr_(vk_device_, "vkDestroyImageView"));
+  auto pfn_update_descriptor_sets =
+      reinterpret_cast<PFN_vkUpdateDescriptorSets>(
+          vk_get_device_proc_addr_(vk_device_, "vkUpdateDescriptorSets"));
+  if (!pfn_create_image_view || !pfn_destroy_image_view ||
+      !pfn_update_descriptor_sets) {
+    return false;
+  }
+
+  // Safe to destroy/update here: every RenderLayer submit fence-waits before
+  // returning, so no previously recorded command buffer is still in flight.
+  if (overlay_view_ != VK_NULL_HANDLE) {
+    pfn_destroy_image_view(vk_device_, overlay_view_, nullptr);
+    overlay_view_ = VK_NULL_HANDLE;
+  }
+
+  VkImageViewCreateInfo view_ci{VK_STRUCTURE_TYPE_IMAGE_VIEW_CREATE_INFO};
+  view_ci.image = overlay_owned_image_.image;
+  view_ci.viewType = VK_IMAGE_VIEW_TYPE_2D;
+  // R8G8B8A8_UNORM: the fragment shader linearizes the sampled gamma-encoded
+  // values itself.
+  view_ci.format = VK_FORMAT_R8G8B8A8_UNORM;
+  view_ci.subresourceRange = {VK_IMAGE_ASPECT_COLOR_BIT, 0, 1, 0, 1};
+  if (pfn_create_image_view(vk_device_, &view_ci, nullptr, &overlay_view_) !=
+      VK_SUCCESS) {
+    LOG(ERROR) << "UpdateOverlayDescriptor: vkCreateImageView failed";
+    overlay_view_ = VK_NULL_HANDLE;
+    return false;
+  }
+
+  VkDescriptorImageInfo image_info{overlay_sampler_, overlay_view_,
+                                   VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL};
+  VkWriteDescriptorSet write{VK_STRUCTURE_TYPE_WRITE_DESCRIPTOR_SET};
+  write.dstSet = overlay_descriptor_set_;
+  write.dstBinding = 0;
+  write.descriptorCount = 1;
+  write.descriptorType = VK_DESCRIPTOR_TYPE_COMBINED_IMAGE_SAMPLER;
+  write.pImageInfo = &image_info;
+  pfn_update_descriptor_sets(vk_device_, 1, &write, 0, nullptr);
+
+  overlay_descriptor_valid_ = true;
+  return true;
+}
