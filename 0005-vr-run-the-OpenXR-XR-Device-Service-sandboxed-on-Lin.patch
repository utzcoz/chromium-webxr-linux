+++ b/content/utility/xr/xr_sandbox_hook_linux.h
@@ -0,0 +1,29 @@
+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CONTENT_UTILITY_XR_XR_SANDBOX_HOOK_LINUX_H_
+#define CONTENT_UTILITY_XR_XR_SANDBOX_HOOK_LINUX_H_
+
+#include "sandbox/policy/linux/sandbox_linux.h"
+
+namespace vr {
+
+// Pre-sandbox hook for the XR Device Service (kXrCompositing) on Linux.
+//
+// The OpenXR loader runs inside the (sandboxed) XR utility process. Before the
+// sandbox seals, this hook:
+//   * dlopen()s the OpenXR loader so its code (and, transitively, the active
+//     runtime's library named by active_runtime.json) is mapped while the
+//     process still has full filesystem access, and
+//   * starts a syscall broker that grants read/open access to the OpenXR
+//     runtime manifest search paths, the runtime library, the Vulkan ICD, and
+//     the DRM render nodes the runtime needs when it creates an XrInstance.
+//
+// Without this the kUtility sandbox blocked the loader from open()ing the file
+// pointed to by active_runtime.json, which is why --no-sandbox was required.
+bool XrPreSandboxHook(sandbox::policy::SandboxLinux::Options options);
+
+}  // namespace vr
+
+#endif  // CONTENT_UTILITY_XR_XR_SANDBOX_HOOK_LINUX_H_
