+  ]
+
+  public_deps = [ "//sandbox/policy" ]
+}
diff --git a/content/utility/xr/xr_sandbox_hook_linux.cc b/content/utility/xr/xr_sandbox_hook_linux.cc
new file mode 100644
index 0000000000000..53d98e6ff70ba
--- /dev/null
+++ b/content/utility/xr/xr_sandbox_hook_linux.cc
@@ -0,0 +1,141 @@
+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/utility/xr/xr_sandbox_hook_linux.h"
+
+#include <stdlib.h>
+
+#include <string>
+#include <vector>
+
+#include "base/files/file_path.h"
+#include "base/strings/string_split.h"
+#include "base/strings/stringprintf.h"
+#include "sandbox/linux/syscall_broker/broker_command.h"
+#include "sandbox/linux/syscall_broker/broker_file_permission.h"
+
+using sandbox::syscall_broker::BrokerFilePermission;
+using sandbox::syscall_broker::MakeBrokerCommandSet;
+
+namespace vr {
+
+namespace {
+
+// Returns the env var |name|, or an empty string if unset/empty.
+std::string GetEnv(const char* name) {
+  const char* value = getenv(name);
+  return (value && value[0]) ? std::string(value) : std::string();
+}
+
+// Files and directories the OpenXR loader, the Vulkan loader, and the OpenXR
+// runtime open()/stat() from inside the XR utility process. Everything is
+// read-only: the swapchain images are shared with the compositor over the IPC
+// socket and DMA-BUF fds, not through brokered files.
+std::vector<BrokerFilePermission> GetOpenXrFilePermissions() {
+  std::vector<BrokerFilePermission> permissions{
+      BrokerFilePermission::ReadOnly("/dev/urandom"),
+      BrokerFilePermission::ReadOnly("/etc/ld.so.cache"),
+  };
+
+  auto add_dir = [&permissions](const std::string& dir) {
+    if (dir.empty()) {
+      return;
+    }
+    permissions.push_back(BrokerFilePermission::ReadOnlyRecursive(
+        base::FilePath(dir).AsEndingWithSeparator().value()));
+  };
+
+  // The OpenXR loader resolves the active runtime manifest
+  // (active_runtime.json) before dlopen()ing the runtime named by its
+  // "library_path". $XR_RUNTIME_JSON points at the manifest directly;
+  // otherwise it searches the XDG config directories. Mirror that search so
+  // the manifest is reachable regardless of how the runtime was installed.
+  std::string runtime_json = GetEnv("XR_RUNTIME_JSON");
+  if (!runtime_json.empty()) {
+    base::FilePath manifest(runtime_json);
+    permissions.push_back(BrokerFilePermission::ReadOnly(manifest.value()));
+    add_dir(manifest.DirName().value());
+  }
+
+  std::string config_home = GetEnv("XDG_CONFIG_HOME");
+  if (config_home.empty()) {
+    std::string home = GetEnv("HOME");
+    if (!home.empty()) {
+      config_home = home + "/.config";
+    }
+  }
+  if (!config_home.empty()) {
+    add_dir(config_home + "/openxr");
+  }
+
+  std::string config_dirs = GetEnv("XDG_CONFIG_DIRS");
+  if (config_dirs.empty()) {
+    config_dirs = "/etc/xdg";
+  }
+  for (const auto& dir :
+       base::SplitString(config_dirs, ":", base::TRIM_WHITESPACE,
+                         base::SPLIT_WANT_NONEMPTY)) {
+    add_dir(dir + "/openxr");
+  }
+  add_dir("/etc/openxr");
+  add_dir("/usr/share/openxr");
+  add_dir("/usr/local/share/openxr");
+
+  // The runtime .so (e.g. libopenxr_monado.so), the Vulkan loader, the Vulkan
+  // ICD driver and their dependency closure live under the system library
+  // directories. The dynamic loader open()s them via the broker after the
+  // sandbox seals.
+  add_dir("/usr/lib");
+  add_dir("/usr/local/lib");
+  add_dir("/lib");
+
+  // Vulkan ICD manifests describing the installed driver.
+  add_dir("/usr/share/vulkan");
+  add_dir("/etc/vulkan");
+
+  // The OpenXR runtime creates its own Vulkan instance in this process at
+  // session start, so it needs the same GPU access the GPU process has: the
+  // DRM nodes (read-write) plus the device's sysfs entries the driver reads
+  // while enumerating physical devices.
+  permissions.push_back(BrokerFilePermission::ReadOnly("/dev/dri"));
+  for (int i = 0; i < 8; ++i) {
+    permissions.push_back(BrokerFilePermission::ReadWrite(
+        base::StringPrintf("/dev/dri/renderD%d", 128 + i)));
+    permissions.push_back(
+        BrokerFilePermission::ReadWrite(base::StringPrintf("/dev/dri/card%d", i)));
+  }
+  add_dir("/sys/dev/char");
+  add_dir("/sys/class/drm");
+  add_dir("/sys/devices");
+  add_dir("/sys/bus/pci/devices");
+
+  return permissions;
+}
+
+}  // namespace
+
+bool XrPreSandboxHook(sandbox::policy::SandboxLinux::Options options) {
+  // The broker forks and therefore must run while single-threaded; do not load
+  // any library here, as the Vulkan loader / ICD driver spawn worker threads.
+  // The OpenXR loader and the Vulkan loader open everything they need through
+  // the broker after the sandbox seals.
+  auto* instance = sandbox::policy::SandboxLinux::GetInstance();
+  instance->StartBrokerProcess(
+      MakeBrokerCommandSet({
+          sandbox::syscall_broker::COMMAND_ACCESS,
+          sandbox::syscall_broker::COMMAND_OPEN,
+          sandbox::syscall_broker::COMMAND_READLINK,
+          sandbox::syscall_broker::COMMAND_STAT,
+      }),
+      GetOpenXrFilePermissions(), options);
+  // NOTE: intentionally do not call EngageNamespaceSandboxIfPossible() here.
+  // The OpenXR runtime connects to its compositor over a host AF_UNIX socket
+  // ($XDG_RUNTIME_DIR/<runtime>_comp_ipc); the network namespace the namespace
+  // sandbox installs makes that connect() fail. The process is still confined
+  // by the seccomp policy (XrProcessPolicy) and the file broker.
+
+  return true;
+}
+
+}  // namespace vr
