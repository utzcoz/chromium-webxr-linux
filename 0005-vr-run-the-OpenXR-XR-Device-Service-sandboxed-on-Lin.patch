+# found in the LICENSE file.
+
+# Pre-sandbox hook for the XR Device Service (kXrCompositing) on Linux. Loads
+# the OpenXR runtime and grants the broker file access the runtime needs before
+# the sandbox seals.
+source_set("xr_sandbox_hook") {
+  sources = [
+    "xr_sandbox_hook_linux.cc",
+    "xr_sandbox_hook_linux.h",
