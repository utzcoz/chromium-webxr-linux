+OpenXrGraphicsBindingVulkan::OpenXrGraphicsBindingVulkan(
+    const OpenXrExtensionEnumeration* extension_enum)
+    : OpenXrGraphicsBinding(extension_enum) {}
+
+OpenXrGraphicsBindingVulkan::~OpenXrGraphicsBindingVulkan() {
+  DestroyVulkanState();
+}
+
+void OpenXrGraphicsBindingVulkan::DestroyCommandPool() {
+  if (vk_device_ != VK_NULL_HANDLE && vk_get_device_proc_addr_) {
+    if (vk_frame_fence_ != VK_NULL_HANDLE) {
+      auto pfn_destroy_fence = reinterpret_cast<PFN_vkDestroyFence>(
+          vk_get_device_proc_addr_(vk_device_, "vkDestroyFence"));
+      if (pfn_destroy_fence) {
+        pfn_destroy_fence(vk_device_, vk_frame_fence_, nullptr);
+      }
+      vk_frame_fence_ = VK_NULL_HANDLE;
+    }
+    if (vk_command_pool_ != VK_NULL_HANDLE) {
+      auto pfn_destroy_command_pool =
+          reinterpret_cast<PFN_vkDestroyCommandPool>(
+              vk_get_device_proc_addr_(vk_device_, "vkDestroyCommandPool"));
+      if (pfn_destroy_command_pool) {
+        pfn_destroy_command_pool(vk_device_, vk_command_pool_, nullptr);
+      }
+    }
+  }
+  vk_command_pool_ = VK_NULL_HANDLE;
+  vk_command_buffer_ = VK_NULL_HANDLE;  // Freed with the pool.
+  // vk_queue_ lifetime is tied to VkDevice; nulled in DestroyVulkanState.
+}
+
+void OpenXrGraphicsBindingVulkan::DestroyVulkanState() {
+  DestroyOverlayImage();
+  DestroyIntermediateImages();
+  DestroyCommandPool();
+  vk_queue_ = VK_NULL_HANDLE;  // Queue lifetime is tied to VkDevice.
+  if (vk_device_ != VK_NULL_HANDLE && vk_destroy_device_) {
+    vk_destroy_device_(vk_device_, nullptr);
+    vk_device_ = VK_NULL_HANDLE;
+  }
+  if (vk_instance_ != VK_NULL_HANDLE && vk_destroy_instance_) {
+    vk_destroy_instance_(vk_instance_, nullptr);
+    vk_instance_ = VK_NULL_HANDLE;
+  }
+  binding_ = {XR_TYPE_GRAPHICS_BINDING_VULKAN2_KHR};
+  initialized_ = false;
+}
+
+bool OpenXrGraphicsBindingVulkan::Initialize(XrInstance instance,
+                                             XrSystemId system) {
+  if (initialized_) {
+    return true;
+  }
+
+  // --- Step 1: Load the Vulkan loader and get vkGetInstanceProcAddr ---------
+  if (!vulkan_loader_.is_valid()) {
+    base::NativeLibraryLoadError error;
+    vulkan_loader_ = base::ScopedNativeLibrary(
+        base::LoadNativeLibrary(base::FilePath("libvulkan.so.1"), &error));
+    if (!vulkan_loader_.is_valid()) {
+      DVLOG(1) << __func__
+               << " Failed to load libvulkan.so.1: " << error.ToString();
+      return false;
+    }
+  }
+
+  vk_get_instance_proc_addr_ =
+      reinterpret_cast<PFN_vkGetInstanceProcAddr>(
+          vulkan_loader_.GetFunctionPointer("vkGetInstanceProcAddr"));
+  if (!vk_get_instance_proc_addr_) {
+    DVLOG(1) << __func__ << " Failed to resolve vkGetInstanceProcAddr";
+    return false;
+  }
+
+  // --- Step 2: Resolve XR function pointers ---------------------------------
+  PFN_xrGetVulkanGraphicsRequirements2KHR xr_get_vulkan_graphics_reqs = nullptr;
+  PFN_xrCreateVulkanInstanceKHR xr_create_vulkan_instance = nullptr;
+  PFN_xrGetVulkanGraphicsDevice2KHR xr_get_vulkan_graphics_device = nullptr;
+  PFN_xrCreateVulkanDeviceKHR xr_create_vulkan_device = nullptr;
+
+  if (XR_FAILED(xrGetInstanceProcAddr(
+          instance, "xrGetVulkanGraphicsRequirements2KHR",
+          reinterpret_cast<PFN_xrVoidFunction*>(
+              &xr_get_vulkan_graphics_reqs))) ||
+      !xr_get_vulkan_graphics_reqs) {
+    DVLOG(1) << __func__
+             << " Failed to resolve xrGetVulkanGraphicsRequirements2KHR";
+    return false;
+  }
+  if (XR_FAILED(xrGetInstanceProcAddr(
+          instance, "xrCreateVulkanInstanceKHR",
+          reinterpret_cast<PFN_xrVoidFunction*>(
+              &xr_create_vulkan_instance))) ||
+      !xr_create_vulkan_instance) {
+    DVLOG(1) << __func__ << " Failed to resolve xrCreateVulkanInstanceKHR";
+    return false;
+  }
+  if (XR_FAILED(xrGetInstanceProcAddr(
+          instance, "xrGetVulkanGraphicsDevice2KHR",
+          reinterpret_cast<PFN_xrVoidFunction*>(
+              &xr_get_vulkan_graphics_device))) ||
+      !xr_get_vulkan_graphics_device) {
+    DVLOG(1) << __func__ << " Failed to resolve xrGetVulkanGraphicsDevice2KHR";
+    return false;
+  }
+  if (XR_FAILED(xrGetInstanceProcAddr(
+          instance, "xrCreateVulkanDeviceKHR",
+          reinterpret_cast<PFN_xrVoidFunction*>(&xr_create_vulkan_device))) ||
+      !xr_create_vulkan_device) {
+    DVLOG(1) << __func__ << " Failed to resolve xrCreateVulkanDeviceKHR";
+    return false;
+  }
+
+  // --- Step 3: Query Vulkan graphics requirements ---------------------------
+  XrGraphicsRequirementsVulkan2KHR reqs{
+      XR_TYPE_GRAPHICS_REQUIREMENTS_VULKAN2_KHR};
+  if (XR_FAILED(xr_get_vulkan_graphics_reqs(instance, system, &reqs))) {
+    DVLOG(1) << __func__
+             << " xrGetVulkanGraphicsRequirements2KHR failed";
+    return false;
+  }
+
+  // --- Step 4: Create VkInstance via xrCreateVulkanInstanceKHR --------------
+  VkApplicationInfo app_info{};
+  app_info.sType = VK_STRUCTURE_TYPE_APPLICATION_INFO;
+  app_info.pApplicationName = "Chromium";
+  app_info.apiVersion = VK_MAKE_VERSION(
+      XR_VERSION_MAJOR(reqs.minApiVersionSupported),
+      XR_VERSION_MINOR(reqs.minApiVersionSupported), 0);
+
+  VkInstanceCreateInfo vk_instance_ci{};
+  vk_instance_ci.sType = VK_STRUCTURE_TYPE_INSTANCE_CREATE_INFO;
+  vk_instance_ci.pApplicationInfo = &app_info;
+
+  XrVulkanInstanceCreateInfoKHR xr_vk_instance_ci{
+      XR_TYPE_VULKAN_INSTANCE_CREATE_INFO_KHR};
+  xr_vk_instance_ci.systemId = system;
+  xr_vk_instance_ci.pfnGetInstanceProcAddr = vk_get_instance_proc_addr_;
+  xr_vk_instance_ci.vulkanCreateInfo = &vk_instance_ci;
+  xr_vk_instance_ci.vulkanAllocator = nullptr;
+
+  VkResult vk_result = VK_ERROR_UNKNOWN;
+  XrResult xr_result = xr_create_vulkan_instance(instance, &xr_vk_instance_ci,
+                                                  &vk_instance_, &vk_result);
+  if (XR_FAILED(xr_result) || vk_result != VK_SUCCESS) {
+    DVLOG(1) << __func__ << " xrCreateVulkanInstanceKHR failed: xr="
+             << xr_result << " vk=" << vk_result;
+    return false;
+  }
+
+  // Resolve instance-level destroy function for cleanup.
+  vk_destroy_instance_ = reinterpret_cast<PFN_vkDestroyInstance>(
+      vk_get_instance_proc_addr_(vk_instance_, "vkDestroyInstance"));
+
+  // --- Step 5: Pick VkPhysicalDevice via xrGetVulkanGraphicsDevice2KHR ------
+  XrVulkanGraphicsDeviceGetInfoKHR get_info{
+      XR_TYPE_VULKAN_GRAPHICS_DEVICE_GET_INFO_KHR};
+  get_info.systemId = system;
+  get_info.vulkanInstance = vk_instance_;
+
+  VkPhysicalDevice physical_device = VK_NULL_HANDLE;
+  if (XR_FAILED(
+          xr_get_vulkan_graphics_device(instance, &get_info,
+                                        &physical_device)) ||
+      physical_device == VK_NULL_HANDLE) {
+    DVLOG(1) << __func__ << " xrGetVulkanGraphicsDevice2KHR failed";
+    DestroyVulkanState();
+    return false;
+  }
+
+  // --- Step 5b: Query VkPhysicalDeviceProperties for real limits ------------
+  auto pfn_get_props =
+      reinterpret_cast<PFN_vkGetPhysicalDeviceProperties>(
+          vk_get_instance_proc_addr_(vk_instance_,
+                                     "vkGetPhysicalDeviceProperties"));
+  if (pfn_get_props) {
+    VkPhysicalDeviceProperties props{};
+    pfn_get_props(physical_device, &props);
+    max_texture_size_ =
+        gfx::Size(static_cast<int>(props.limits.maxImageDimension2D),
+                  static_cast<int>(props.limits.maxImageDimension2D));
+    DVLOG(1) << __func__ << " maxImageDimension2D="
+             << props.limits.maxImageDimension2D;
+  }
+
+  // --- Step 6: Find a graphics-capable queue family -------------------------
+  auto pfn_get_queue_family_props =
+      reinterpret_cast<PFN_vkGetPhysicalDeviceQueueFamilyProperties>(
+          vk_get_instance_proc_addr_(
+              vk_instance_, "vkGetPhysicalDeviceQueueFamilyProperties"));
+  if (!pfn_get_queue_family_props) {
+    DVLOG(1) << __func__
+             << " Failed to resolve vkGetPhysicalDeviceQueueFamilyProperties";
+    DestroyVulkanState();
+    return false;
+  }
+
+  uint32_t queue_family_count = 0;
+  pfn_get_queue_family_props(physical_device, &queue_family_count, nullptr);
+  std::vector<VkQueueFamilyProperties> queue_families(queue_family_count);
+  pfn_get_queue_family_props(physical_device, &queue_family_count,
+                             queue_families.data());
+
+  uint32_t graphics_queue_family_index = UINT32_MAX;
+  for (uint32_t i = 0; i < queue_family_count; ++i) {
+    if (queue_families[i].queueFlags & VK_QUEUE_GRAPHICS_BIT) {
+      graphics_queue_family_index = i;
+      break;
+    }
+  }
+  if (graphics_queue_family_index == UINT32_MAX) {
+    DVLOG(1) << __func__ << " No graphics-capable queue family found";
+    DestroyVulkanState();
+    return false;
+  }
+
+  // --- Step 7: Create VkDevice via xrCreateVulkanDeviceKHR ------------------
+
+  // Enumerate supported device extensions so we can filter our request list.
+  auto pfn_enumerate_device_extensions =
+      reinterpret_cast<PFN_vkEnumerateDeviceExtensionProperties>(
+          vk_get_instance_proc_addr_(vk_instance_,
+                                     "vkEnumerateDeviceExtensionProperties"));
+
+  std::vector<VkExtensionProperties> available_device_extensions;
+  if (pfn_enumerate_device_extensions) {
+    uint32_t ext_count = 0;
+    pfn_enumerate_device_extensions(physical_device, nullptr, &ext_count,
+                                    nullptr);
+    available_device_extensions.resize(ext_count);
+    pfn_enumerate_device_extensions(physical_device, nullptr, &ext_count,
+                                    available_device_extensions.data());
+  }
+
+  auto IsExtensionSupported = [&](const char* name) -> bool {
+    return std::ranges::any_of(
+        available_device_extensions,
+        [name](const VkExtensionProperties& ext) {
+          return std::string_view(ext.extensionName) == name;
+        });
+  };
+
+  std::vector<const char*> device_extensions;
+  auto MaybeAdd = [&](const char* name) -> bool {
+    if (IsExtensionSupported(name)) {
+      device_extensions.push_back(name);
+      return true;
+    }
+    DVLOG(1) << "Device extension not available: " << name;
+    return false;
+  };
+
+  MaybeAdd(VK_KHR_DEDICATED_ALLOCATION_EXTENSION_NAME);
+  MaybeAdd(VK_KHR_GET_MEMORY_REQUIREMENTS_2_EXTENSION_NAME);
+  MaybeAdd(VK_KHR_IMAGE_FORMAT_LIST_EXTENSION_NAME);
+  MaybeAdd(VK_KHR_EXTERNAL_MEMORY_EXTENSION_NAME);
+  has_external_memory_fd_ = MaybeAdd(VK_KHR_EXTERNAL_MEMORY_FD_EXTENSION_NAME);
+  MaybeAdd("VK_EXT_external_memory_dma_buf");
+  MaybeAdd(VK_KHR_EXTERNAL_SEMAPHORE_EXTENSION_NAME);
+  has_external_semaphore_fd_ =
+      MaybeAdd(VK_KHR_EXTERNAL_SEMAPHORE_FD_EXTENSION_NAME);
+  MaybeAdd(VK_KHR_EXTERNAL_FENCE_EXTENSION_NAME);
+  MaybeAdd(VK_KHR_EXTERNAL_FENCE_FD_EXTENSION_NAME);
+
+  float queue_priority = 1.0f;
+  VkDeviceQueueCreateInfo queue_ci{};
+  queue_ci.sType = VK_STRUCTURE_TYPE_DEVICE_QUEUE_CREATE_INFO;
+  queue_ci.queueFamilyIndex = graphics_queue_family_index;
+  queue_ci.queueCount = 1;
+  queue_ci.pQueuePriorities = &queue_priority;
+
+  VkDeviceCreateInfo vk_device_ci{};
+  vk_device_ci.sType = VK_STRUCTURE_TYPE_DEVICE_CREATE_INFO;
+  vk_device_ci.queueCreateInfoCount = 1;
+  vk_device_ci.pQueueCreateInfos = &queue_ci;
+  vk_device_ci.enabledExtensionCount =
+      static_cast<uint32_t>(device_extensions.size());
+  vk_device_ci.ppEnabledExtensionNames = device_extensions.data();
+
+  XrVulkanDeviceCreateInfoKHR xr_vk_device_ci{
+      XR_TYPE_VULKAN_DEVICE_CREATE_INFO_KHR};
+  xr_vk_device_ci.systemId = system;
+  xr_vk_device_ci.pfnGetInstanceProcAddr = vk_get_instance_proc_addr_;
+  xr_vk_device_ci.vulkanPhysicalDevice = physical_device;
+  xr_vk_device_ci.vulkanCreateInfo = &vk_device_ci;
+  xr_vk_device_ci.vulkanAllocator = nullptr;
+
+  vk_result = VK_ERROR_UNKNOWN;
+  xr_result = xr_create_vulkan_device(instance, &xr_vk_device_ci, &vk_device_,
+                                      &vk_result);
+  if (XR_FAILED(xr_result) || vk_result != VK_SUCCESS) {
+    DVLOG(1) << __func__ << " xrCreateVulkanDeviceKHR failed: xr="
+             << xr_result << " vk=" << vk_result;
+    DestroyVulkanState();
+    return false;
+  }
+
+  // Resolve device-level function pointers.
+  vk_get_device_proc_addr_ = reinterpret_cast<PFN_vkGetDeviceProcAddr>(
+      vk_get_instance_proc_addr_(vk_instance_, "vkGetDeviceProcAddr"));
+  vk_destroy_device_ = reinterpret_cast<PFN_vkDestroyDevice>(
+      vk_get_instance_proc_addr_(vk_instance_, "vkDestroyDevice"));
+
+  // --- Step 8: Retrieve the VkQueue and create a command pool ---------------
+  // The queue, command pool, and buffer are only needed when
+  // has_external_memory_fd_ is true (i.e., on real hardware with FD export
+  // support). On SwiftShader (used in tests), RenderLayer and WaitOnFence
+  // early-return so no blit/sync infrastructure is needed.
+  if (has_external_memory_fd_) {
+    auto pfn_get_queue = reinterpret_cast<PFN_vkGetDeviceQueue>(
+        vk_get_device_proc_addr_(vk_device_, "vkGetDeviceQueue"));
+    if (!pfn_get_queue) {
+      DVLOG(1) << __func__ << " Failed to resolve vkGetDeviceQueue";
+      DestroyVulkanState();
+      return false;
+    }
+    pfn_get_queue(vk_device_, graphics_queue_family_index, 0, &vk_queue_);
+    auto pfn_create_command_pool = reinterpret_cast<PFN_vkCreateCommandPool>(
+        vk_get_device_proc_addr_(vk_device_, "vkCreateCommandPool"));
+    auto pfn_allocate_command_buffers =
+        reinterpret_cast<PFN_vkAllocateCommandBuffers>(
+            vk_get_device_proc_addr_(vk_device_, "vkAllocateCommandBuffers"));
+    if (!pfn_create_command_pool || !pfn_allocate_command_buffers) {
+      DVLOG(1) << __func__
+               << " Failed to resolve command pool/buffer functions";
+      DestroyVulkanState();
+      return false;
+    }
+
+    VkCommandPoolCreateInfo pool_ci{VK_STRUCTURE_TYPE_COMMAND_POOL_CREATE_INFO};
+    pool_ci.flags = VK_COMMAND_POOL_CREATE_RESET_COMMAND_BUFFER_BIT;
+    pool_ci.queueFamilyIndex = graphics_queue_family_index;
+    if (pfn_create_command_pool(vk_device_, &pool_ci, nullptr,
+                                &vk_command_pool_) != VK_SUCCESS) {
+      DVLOG(1) << __func__ << " vkCreateCommandPool failed";
+      DestroyVulkanState();
+      return false;
+    }
+
+    VkCommandBufferAllocateInfo cb_ai{
+        VK_STRUCTURE_TYPE_COMMAND_BUFFER_ALLOCATE_INFO};
+    cb_ai.commandPool = vk_command_pool_;
+    cb_ai.level = VK_COMMAND_BUFFER_LEVEL_PRIMARY;
+    cb_ai.commandBufferCount = 1;
+    if (pfn_allocate_command_buffers(vk_device_, &cb_ai,
+                                     &vk_command_buffer_) != VK_SUCCESS) {
+      DVLOG(1) << __func__ << " vkAllocateCommandBuffers failed";
+      DestroyVulkanState();
+      return false;
+    }
+
+    // Create a reusable fence for fence-based submit/wait in WaitOnFence and
+    // RenderLayer, replacing per-call vkQueueWaitIdle.
+    auto pfn_create_fence = reinterpret_cast<PFN_vkCreateFence>(
+        vk_get_device_proc_addr_(vk_device_, "vkCreateFence"));
+    if (!pfn_create_fence) {
+      DVLOG(1) << __func__ << " Failed to resolve vkCreateFence";
+      DestroyVulkanState();
+      return false;
+    }
+    VkFenceCreateInfo fence_ci{VK_STRUCTURE_TYPE_FENCE_CREATE_INFO};
+    if (pfn_create_fence(vk_device_, &fence_ci, nullptr, &vk_frame_fence_) !=
+        VK_SUCCESS) {
+      DVLOG(1) << __func__ << " vkCreateFence failed";
+      DestroyVulkanState();
+      return false;
+    }
+  }
+
+  // --- Step 9: Populate the graphics binding struct -------------------------
+  binding_.instance = vk_instance_;
+  binding_.physicalDevice = physical_device;
+  binding_.device = vk_device_;
+  binding_.queueFamilyIndex = graphics_queue_family_index;
+  binding_.queueIndex = 0;
+
+  initialized_ = true;
+  return true;
+}
+
+const void* OpenXrGraphicsBindingVulkan::GetSessionCreateInfo() const {
+  return initialized_ ? &binding_ : nullptr;
+}
+
+int64_t OpenXrGraphicsBindingVulkan::GetSwapchainFormat(
+    XrSession session) const {
+  uint32_t count = 0;
+  if (XR_FAILED(xrEnumerateSwapchainFormats(session, 0, &count, nullptr)) ||
+      count == 0) {
+    return 0;
+  }
+  std::vector<int64_t> formats(count);
+  if (XR_FAILED(
+          xrEnumerateSwapchainFormats(session, count, &count, formats.data()))) {
+    return 0;
+  }
+
+  // Prefer SRGB formats for correct color rendering. Try RGBA first (matches
+  // the SharedImage default), fall back to BGRA, otherwise accept formats[0].
+  int64_t selected = formats[0];
+  bool found = false;
+  for (int64_t f : formats) {
+    if (f == VK_FORMAT_R8G8B8A8_SRGB) {
+      selected = f;
+      found = true;
+      break;
+    }
+  }
+  if (!found) {
+    for (int64_t f : formats) {
+      if (f == VK_FORMAT_B8G8R8A8_SRGB) {
+        selected = f;
+        break;
+      }
+    }
+  }
+  // Cache the negotiated format so CreateSharedImages() can create matching
+  // intermediate images without needing to re-query the session.
+  swapchain_format_ = static_cast<VkFormat>(selected);
+  return selected;
+}
+
+XrResult OpenXrGraphicsBindingVulkan::EnumerateSwapchainImages(
+    OpenXrCompositionLayer& layer) {
+  CHECK(layer.HasColorSwapchain());
+  CHECK(layer.GetSwapchainImages().empty());
+
+  uint32_t chain_length = 0;
+  RETURN_IF_XR_FAILED(xrEnumerateSwapchainImages(layer.color_swapchain(), 0,
+                                                  &chain_length, nullptr));
+
+  std::vector<XrSwapchainImageVulkan2KHR> xr_color_swapchain_images(
+      chain_length, {XR_TYPE_SWAPCHAIN_IMAGE_VULKAN2_KHR});
+
+  RETURN_IF_XR_FAILED(xrEnumerateSwapchainImages(
+      layer.color_swapchain(), xr_color_swapchain_images.size(), &chain_length,
+      reinterpret_cast<XrSwapchainImageBaseHeader*>(
+          xr_color_swapchain_images.data())));
+
+  std::vector<OpenXrSwapchainInfo> color_swapchain_images;
+  color_swapchain_images.reserve(xr_color_swapchain_images.size());
+  for (const auto& swapchain_image : xr_color_swapchain_images) {
+    color_swapchain_images.emplace_back(swapchain_image.image);
+  }
+  layer.SetSwapchainImages(std::move(color_swapchain_images));
+
+  return XR_SUCCESS;
+}
+
+bool OpenXrGraphicsBindingVulkan::CreateIntermediateImage(
+    const gfx::Size& size,
+    VkFormat format,
+    IntermediateImage* out_image) {
+  CHECK(vk_get_device_proc_addr_);
+  CHECK(vk_device_ != VK_NULL_HANDLE);
+
+  auto pfn_create_image = reinterpret_cast<PFN_vkCreateImage>(
+      vk_get_device_proc_addr_(vk_device_, "vkCreateImage"));
+  auto pfn_get_memory_reqs =
+      reinterpret_cast<PFN_vkGetImageMemoryRequirements>(
+          vk_get_device_proc_addr_(vk_device_,
+                                   "vkGetImageMemoryRequirements"));
+  auto pfn_allocate_memory = reinterpret_cast<PFN_vkAllocateMemory>(
+      vk_get_device_proc_addr_(vk_device_, "vkAllocateMemory"));
+  auto pfn_bind_image_memory = reinterpret_cast<PFN_vkBindImageMemory>(
+      vk_get_device_proc_addr_(vk_device_, "vkBindImageMemory"));
+  auto pfn_get_physical_device_memory_properties =
+      reinterpret_cast<PFN_vkGetPhysicalDeviceMemoryProperties>(
+          vk_get_instance_proc_addr_(vk_instance_,
+                                     "vkGetPhysicalDeviceMemoryProperties"));
+
+  if (!pfn_create_image || !pfn_get_memory_reqs || !pfn_allocate_memory ||
+      !pfn_bind_image_memory || !pfn_get_physical_device_memory_properties) {
+    LOG(ERROR) << "CreateIntermediateImage: Failed to resolve Vulkan functions";
+    return false;
+  }
+
+  // Chain VkExternalMemoryImageCreateInfo to enable DMA-BUF export.
+  // DMA-BUF (not OPAQUE_FD) is required for cross-API sharing with GL.
+  VkExternalMemoryImageCreateInfo external_image_info{};
+  external_image_info.sType =
+      VK_STRUCTURE_TYPE_EXTERNAL_MEMORY_IMAGE_CREATE_INFO;
+  external_image_info.handleTypes =
+      VK_EXTERNAL_MEMORY_HANDLE_TYPE_DMA_BUF_BIT_EXT;
+
+  VkImageCreateInfo image_ci{};
+  image_ci.sType = VK_STRUCTURE_TYPE_IMAGE_CREATE_INFO;
+  image_ci.pNext = &external_image_info;
+  image_ci.imageType = VK_IMAGE_TYPE_2D;
+  image_ci.format = format;
+  image_ci.extent = {static_cast<uint32_t>(size.width()),
+                     static_cast<uint32_t>(size.height()), 1};
+  image_ci.mipLevels = 1;
+  image_ci.arrayLayers = 1;
+  image_ci.samples = VK_SAMPLE_COUNT_1_BIT;
+  // LINEAR tiling ensures a well-defined memory layout (queryable stride)
+  // that the GL-based GPU process can correctly interpret via DMA-BUF.
+  image_ci.tiling = VK_IMAGE_TILING_LINEAR;
+  image_ci.usage = VK_IMAGE_USAGE_TRANSFER_SRC_BIT |
+                   VK_IMAGE_USAGE_TRANSFER_DST_BIT |
+                   VK_IMAGE_USAGE_COLOR_ATTACHMENT_BIT;
+  image_ci.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+  image_ci.initialLayout = VK_IMAGE_LAYOUT_UNDEFINED;
+
+  VkImage image = VK_NULL_HANDLE;
+  if (pfn_create_image(vk_device_, &image_ci, nullptr, &image) != VK_SUCCESS) {
+    LOG(ERROR) << "CreateIntermediateImage: vkCreateImage failed";
+    return false;
+  }
+
+  VkMemoryRequirements mem_reqs{};
+  pfn_get_memory_reqs(vk_device_, image, &mem_reqs);
+
+  // Find a device-local memory type that satisfies the image requirements.
+  VkPhysicalDeviceMemoryProperties mem_props{};
+  pfn_get_physical_device_memory_properties(binding_.physicalDevice, &mem_props);
+
+  uint32_t memory_type_index = UINT32_MAX;
+  for (uint32_t i = 0; i < mem_props.memoryTypeCount; ++i) {
+    if ((mem_reqs.memoryTypeBits & (1u << i)) &&
+        (UNSAFE_TODO(mem_props.memoryTypes[i]).propertyFlags &
+         VK_MEMORY_PROPERTY_DEVICE_LOCAL_BIT)) {
+      memory_type_index = i;
+      break;
+    }
+  }
+
+  if (memory_type_index == UINT32_MAX) {
+    LOG(ERROR) << "CreateIntermediateImage: No suitable device-local memory "
+               << "type found";
+    auto pfn_destroy_image = reinterpret_cast<PFN_vkDestroyImage>(
+        vk_get_device_proc_addr_(vk_device_, "vkDestroyImage"));
+    if (pfn_destroy_image) {
+      pfn_destroy_image(vk_device_, image, nullptr);
+    }
+    return false;
+  }
+
+  // Chain VkExportMemoryAllocateInfo to make the memory exportable as DMA-BUF.
+  VkExportMemoryAllocateInfo export_alloc_info{};
+  export_alloc_info.sType = VK_STRUCTURE_TYPE_EXPORT_MEMORY_ALLOCATE_INFO;
+  export_alloc_info.handleTypes =
+      VK_EXTERNAL_MEMORY_HANDLE_TYPE_DMA_BUF_BIT_EXT;
+
+  VkMemoryAllocateInfo alloc_info{};
+  alloc_info.sType = VK_STRUCTURE_TYPE_MEMORY_ALLOCATE_INFO;
+  alloc_info.pNext = &export_alloc_info;
+  alloc_info.allocationSize = mem_reqs.size;
+  alloc_info.memoryTypeIndex = memory_type_index;
+
+  VkDeviceMemory memory = VK_NULL_HANDLE;
+  if (pfn_allocate_memory(vk_device_, &alloc_info, nullptr, &memory) !=
+      VK_SUCCESS) {
+    LOG(ERROR) << "CreateIntermediateImage: vkAllocateMemory failed";
+    auto pfn_destroy_image = reinterpret_cast<PFN_vkDestroyImage>(
+        vk_get_device_proc_addr_(vk_device_, "vkDestroyImage"));
+    if (pfn_destroy_image) {
+      pfn_destroy_image(vk_device_, image, nullptr);
+    }
+    return false;
+  }
+
+  if (pfn_bind_image_memory(vk_device_, image, memory, 0) != VK_SUCCESS) {
+    LOG(ERROR) << "CreateIntermediateImage: vkBindImageMemory failed";
+    auto pfn_destroy_image = reinterpret_cast<PFN_vkDestroyImage>(
+        vk_get_device_proc_addr_(vk_device_, "vkDestroyImage"));
+    auto pfn_free_memory = reinterpret_cast<PFN_vkFreeMemory>(
+        vk_get_device_proc_addr_(vk_device_, "vkFreeMemory"));
+    if (pfn_destroy_image) {
+      pfn_destroy_image(vk_device_, image, nullptr);
+    }
+    if (pfn_free_memory) {
+      pfn_free_memory(vk_device_, memory, nullptr);
+    }
+    return false;
+  }
+
+  // Query the actual row stride for LINEAR tiling.
+  auto pfn_get_image_subresource_layout =
+      reinterpret_cast<PFN_vkGetImageSubresourceLayout>(
+          vk_get_device_proc_addr_(vk_device_,
+                                   "vkGetImageSubresourceLayout"));
+  VkSubresourceLayout layout{};
+  if (pfn_get_image_subresource_layout) {
+    VkImageSubresource subresource{};
+    subresource.aspectMask = VK_IMAGE_ASPECT_COLOR_BIT;
+    subresource.mipLevel = 0;
+    subresource.arrayLayer = 0;
+    pfn_get_image_subresource_layout(vk_device_, image, &subresource, &layout);
+  } else {
+    // Fallback: guess stride.
+    layout.rowPitch = static_cast<uint64_t>(size.width()) * 4;
+    layout.offset = 0;
+    layout.size = layout.rowPitch * size.height();
+  }
+
+  out_image->image = image;
+  out_image->memory = memory;
+  out_image->stride = static_cast<uint32_t>(layout.rowPitch);
+  out_image->offset = static_cast<uint32_t>(layout.offset);
+  out_image->allocation_size = layout.size;
+  return true;
+}
+
+void OpenXrGraphicsBindingVulkan::DestroyIntermediateImages() {
+  if (vk_device_ == VK_NULL_HANDLE || !vk_get_device_proc_addr_) {
+    intermediate_images_.clear();
+    return;
+  }
+
+  auto pfn_destroy_image = reinterpret_cast<PFN_vkDestroyImage>(
+      vk_get_device_proc_addr_(vk_device_, "vkDestroyImage"));
+  auto pfn_free_memory = reinterpret_cast<PFN_vkFreeMemory>(
+      vk_get_device_proc_addr_(vk_device_, "vkFreeMemory"));
+
+  for (auto& img : intermediate_images_) {
+    if (pfn_destroy_image && img.image != VK_NULL_HANDLE) {
+      pfn_destroy_image(vk_device_, img.image, nullptr);
+    }
+    if (pfn_free_memory && img.memory != VK_NULL_HANDLE) {
+      pfn_free_memory(vk_device_, img.memory, nullptr);
+    }
+  }
+  intermediate_images_.clear();
+}
+
+void OpenXrGraphicsBindingVulkan::DestroyOverlayImage() {
+  if (vk_device_ == VK_NULL_HANDLE || !vk_get_device_proc_addr_) {
+    overlay_image_ = VK_NULL_HANDLE;
+    overlay_memory_ = VK_NULL_HANDLE;
+    overlay_layout_ = VK_IMAGE_LAYOUT_UNDEFINED;
+    has_overlay_ = false;
+    return;
+  }
+  if (overlay_image_ != VK_NULL_HANDLE) {
+    auto pfn_destroy_image = reinterpret_cast<PFN_vkDestroyImage>(
+        vk_get_device_proc_addr_(vk_device_, "vkDestroyImage"));
+    if (pfn_destroy_image) {
+      pfn_destroy_image(vk_device_, overlay_image_, nullptr);
+    }
+    overlay_image_ = VK_NULL_HANDLE;
+  }
+  if (overlay_memory_ != VK_NULL_HANDLE) {
+    auto pfn_free_memory = reinterpret_cast<PFN_vkFreeMemory>(
+        vk_get_device_proc_addr_(vk_device_, "vkFreeMemory"));
+    if (pfn_free_memory) {
+      pfn_free_memory(vk_device_, overlay_memory_, nullptr);
+    }
+    overlay_memory_ = VK_NULL_HANDLE;
+  }
+  overlay_layout_ = VK_IMAGE_LAYOUT_UNDEFINED;
+  has_overlay_ = false;
+}
+
+bool OpenXrGraphicsBindingVulkan::ImportOverlayDmaBuf(
+    const gfx::GpuMemoryBufferHandle& handle,
+    const gfx::Size& size,
+    VkFormat format) {
+  CHECK(vk_get_device_proc_addr_);
+  CHECK(vk_device_ != VK_NULL_HANDLE);
+
+  // The browser-side GraphicsDelegate exports its SharedImage as a
+  // NativePixmapHandle wrapping a single DMA-BUF plane.
+  if (handle.type != gfx::NATIVE_PIXMAP) {
+    LOG(ERROR) << "ImportOverlayDmaBuf: handle is not NATIVE_PIXMAP";
+    return false;
+  }
+  const gfx::NativePixmapHandle& pixmap = handle.native_pixmap_handle();
+  if (pixmap.planes.empty() || !pixmap.planes[0].fd.is_valid()) {
+    LOG(ERROR) << "ImportOverlayDmaBuf: no DMA-BUF FD in NativePixmapHandle";
+    return false;
+  }
+
+  // Dup the FD — vkAllocateMemory takes ownership on success.
+  base::ScopedFD dup_fd(dup(pixmap.planes[0].fd.get()));
+  if (!dup_fd.is_valid()) {
+    PLOG(ERROR) << "ImportOverlayDmaBuf: dup() failed";
+    return false;
+  }
+
+  auto pfn_create_image = reinterpret_cast<PFN_vkCreateImage>(
+      vk_get_device_proc_addr_(vk_device_, "vkCreateImage"));
+  auto pfn_allocate_memory = reinterpret_cast<PFN_vkAllocateMemory>(
+      vk_get_device_proc_addr_(vk_device_, "vkAllocateMemory"));
+  auto pfn_bind_image_memory = reinterpret_cast<PFN_vkBindImageMemory>(
+      vk_get_device_proc_addr_(vk_device_, "vkBindImageMemory"));
+  auto pfn_get_image_memory_requirements =
+      reinterpret_cast<PFN_vkGetImageMemoryRequirements>(
+          vk_get_device_proc_addr_(vk_device_, "vkGetImageMemoryRequirements"));
+  auto pfn_get_physical_device_memory_properties =
+      reinterpret_cast<PFN_vkGetPhysicalDeviceMemoryProperties>(
+          vk_get_instance_proc_addr_(vk_instance_,
+                                     "vkGetPhysicalDeviceMemoryProperties"));
+  if (!pfn_create_image || !pfn_allocate_memory || !pfn_bind_image_memory ||
+      !pfn_get_image_memory_requirements ||
+      !pfn_get_physical_device_memory_properties) {
+    LOG(ERROR) << "ImportOverlayDmaBuf: failed to resolve Vulkan functions";
+    return false;
+  }
+
+  // Create VkImage matching the source SharedImage layout (linear, DMA-BUF
+  // externally allocated).
+  VkExternalMemoryImageCreateInfo external_image_info{};
+  external_image_info.sType =
+      VK_STRUCTURE_TYPE_EXTERNAL_MEMORY_IMAGE_CREATE_INFO;
+  external_image_info.handleTypes =
+      VK_EXTERNAL_MEMORY_HANDLE_TYPE_DMA_BUF_BIT_EXT;
+
+  VkImageCreateInfo image_ci{};
+  image_ci.sType = VK_STRUCTURE_TYPE_IMAGE_CREATE_INFO;
+  image_ci.pNext = &external_image_info;
+  image_ci.imageType = VK_IMAGE_TYPE_2D;
+  image_ci.format = format;
+  image_ci.extent = {static_cast<uint32_t>(size.width()),
+                     static_cast<uint32_t>(size.height()), 1};
+  image_ci.mipLevels = 1;
+  image_ci.arrayLayers = 1;
+  image_ci.samples = VK_SAMPLE_COUNT_1_BIT;
+  image_ci.tiling = VK_IMAGE_TILING_LINEAR;
+  image_ci.usage = VK_IMAGE_USAGE_TRANSFER_SRC_BIT;
+  image_ci.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+  image_ci.initialLayout = VK_IMAGE_LAYOUT_UNDEFINED;
+
+  VkImage image = VK_NULL_HANDLE;
+  if (pfn_create_image(vk_device_, &image_ci, nullptr, &image) != VK_SUCCESS) {
+    LOG(ERROR) << "ImportOverlayDmaBuf: vkCreateImage failed";
+    return false;
+  }
+
+  VkMemoryRequirements mem_reqs{};
+  pfn_get_image_memory_requirements(vk_device_, image, &mem_reqs);
+
+  // Find a memory type satisfying the image requirements. For imported DMA-BUF
+  // the actual properties are determined by the exporter; we accept whatever
+  // type matches memoryTypeBits.
+  VkPhysicalDeviceMemoryProperties mem_props{};
+  pfn_get_physical_device_memory_properties(binding_.physicalDevice,
+                                             &mem_props);
+  uint32_t memory_type_index = UINT32_MAX;
+  for (uint32_t i = 0; i < mem_props.memoryTypeCount; ++i) {
+    if (mem_reqs.memoryTypeBits & (1u << i)) {
+      memory_type_index = i;
+      break;
+    }
+  }
+  if (memory_type_index == UINT32_MAX) {
+    LOG(ERROR) << "ImportOverlayDmaBuf: no compatible memory type";
+    auto pfn_destroy_image = reinterpret_cast<PFN_vkDestroyImage>(
+        vk_get_device_proc_addr_(vk_device_, "vkDestroyImage"));
+    if (pfn_destroy_image) {
+      pfn_destroy_image(vk_device_, image, nullptr);
+    }
+    return false;
+  }
+
+  // Chain VkImportMemoryFdInfoKHR to allocate memory from the imported FD.
+  // vkAllocateMemory takes ownership of the FD on success.
+  VkImportMemoryFdInfoKHR import_info{};
+  import_info.sType = VK_STRUCTURE_TYPE_IMPORT_MEMORY_FD_INFO_KHR;
+  import_info.handleType = VK_EXTERNAL_MEMORY_HANDLE_TYPE_DMA_BUF_BIT_EXT;
+  import_info.fd = dup_fd.release();
+
+  VkMemoryAllocateInfo alloc_info{};
+  alloc_info.sType = VK_STRUCTURE_TYPE_MEMORY_ALLOCATE_INFO;
+  alloc_info.pNext = &import_info;
+  alloc_info.allocationSize = mem_reqs.size;
+  alloc_info.memoryTypeIndex = memory_type_index;
+
+  VkDeviceMemory memory = VK_NULL_HANDLE;
+  if (pfn_allocate_memory(vk_device_, &alloc_info, nullptr, &memory) !=
+      VK_SUCCESS) {
+    LOG(ERROR) << "ImportOverlayDmaBuf: vkAllocateMemory failed "
+               << "(imported FD was not consumed; closing)";
+    close(import_info.fd);
+    auto pfn_destroy_image = reinterpret_cast<PFN_vkDestroyImage>(
+        vk_get_device_proc_addr_(vk_device_, "vkDestroyImage"));
+    if (pfn_destroy_image) {
+      pfn_destroy_image(vk_device_, image, nullptr);
+    }
+    return false;
+  }
+
+  if (pfn_bind_image_memory(vk_device_, image, memory, 0) != VK_SUCCESS) {
+    LOG(ERROR) << "ImportOverlayDmaBuf: vkBindImageMemory failed";
+    auto pfn_free_memory = reinterpret_cast<PFN_vkFreeMemory>(
+        vk_get_device_proc_addr_(vk_device_, "vkFreeMemory"));
+    if (pfn_free_memory) {
+      pfn_free_memory(vk_device_, memory, nullptr);
+    }
+    auto pfn_destroy_image = reinterpret_cast<PFN_vkDestroyImage>(
+        vk_get_device_proc_addr_(vk_device_, "vkDestroyImage"));
+    if (pfn_destroy_image) {
+      pfn_destroy_image(vk_device_, image, nullptr);
+    }
+    return false;
+  }
+
+  overlay_image_ = image;
+  overlay_memory_ = memory;
+  overlay_size_ = size;
+  overlay_layout_ = VK_IMAGE_LAYOUT_UNDEFINED;
+  return true;
+}
+
+bool OpenXrGraphicsBindingVulkan::CanUseSharedImages() const {
+  return initialized_;
+}
+
+void OpenXrGraphicsBindingVulkan::CreateSharedImages(
+    OpenXrCompositionLayer& layer,
+    gpu::SharedImageInterface* sii) {
+  CHECK(sii);
+
+  // VK_KHR_external_memory_fd is required to export VkDeviceMemory as FDs.
+  // This extension is not available on SwiftShader, so we skip SharedImage
+  // creation in that case — all unit tests take this early-return path.
+  if (!has_external_memory_fd_) {
+    DVLOG(1) << "CreateSharedImages: VK_KHR_external_memory_fd not available, "
+             << "skipping SharedImage creation";
+    return;
+  }
+
+  if (!vk_get_device_proc_addr_ || vk_device_ == VK_NULL_HANDLE) {
+    DLOG(ERROR) << "CreateSharedImages: Vulkan not initialized";
+    return;
+  }
+
+  const gfx::Size size = layer.GetSwapchainImageSize();
+  DVLOG(1) << "CreateSharedImages: SwapchainImageSize=" << size.ToString()
+           << " TransferSize=" << layer.GetTransferSize().ToString();
+  if (size.IsEmpty()) {
+    DLOG(ERROR) << "CreateSharedImages: Swapchain image size is empty";
+    return;
+  }
+
+  // swapchain_format_ was set by GetSwapchainFormat() during swapchain creation.
+  // Verify it is populated before proceeding.
+  if (swapchain_format_ == VK_FORMAT_UNDEFINED) {
+    LOG(ERROR) << "CreateSharedImages: swapchain format not yet negotiated";
+    return;
+  }
+
+  // Destroy any previously created intermediate images.
+  DestroyIntermediateImages();
+
+  auto pfn_get_memory_fd = reinterpret_cast<PFN_vkGetMemoryFdKHR>(
+      vk_get_device_proc_addr_(vk_device_, "vkGetMemoryFdKHR"));
+  if (!pfn_get_memory_fd) {
+    LOG(ERROR) << "CreateSharedImages: vkGetMemoryFdKHR not available";
+    return;
+  }
+
+  auto swapchain_images = layer.GetSwapchainImages();
+  intermediate_images_.resize(swapchain_images.size());
+
+  for (size_t i = 0; i < swapchain_images.size(); ++i) {
+    if (!CreateIntermediateImage(size, swapchain_format_,
+                                &intermediate_images_[i])) {
+      LOG(ERROR) << "Failed to create intermediate image " << i;
+      DestroyIntermediateImages();
+      return;
+    }
+
+    // Export the VkDeviceMemory as a DMA-BUF file descriptor.
+    int fd = -1;
+    VkMemoryGetFdInfoKHR fd_info{};
+    fd_info.sType = VK_STRUCTURE_TYPE_MEMORY_GET_FD_INFO_KHR;
+    fd_info.memory = intermediate_images_[i].memory;
+    fd_info.handleType = VK_EXTERNAL_MEMORY_HANDLE_TYPE_DMA_BUF_BIT_EXT;
+
+    if (pfn_get_memory_fd(vk_device_, &fd_info, &fd) != VK_SUCCESS || fd < 0) {
+      LOG(ERROR) << "vkGetMemoryFdKHR (DMA_BUF) failed for image " << i;
+      DestroyIntermediateImages();
+      return;
+    }
+
+    // Wrap the DMA-BUF FD with proper stride from VkSubresourceLayout.
+    gfx::NativePixmapHandle pixmap_handle;
+    pixmap_handle.modifier = 0;  // DRM_FORMAT_MOD_LINEAR
+    pixmap_handle.planes.emplace_back(
+        /*stride=*/intermediate_images_[i].stride,
+        /*offset=*/intermediate_images_[i].offset,
+        /*size=*/intermediate_images_[i].allocation_size,
+        base::ScopedFD(fd));
+
+    gfx::GpuMemoryBufferHandle gmb_handle(std::move(pixmap_handle));
+
+    // The SharedImages created here will be transferred to other processes to
+    // have their contents written by WebGL or WebGPU. Readback by OpenXR is
+    // via the blit in RenderLayer.
+    gpu::SharedImageUsageSet shared_image_usage =
+        gpu::SHARED_IMAGE_USAGE_SCANOUT |
+        gpu::SHARED_IMAGE_USAGE_DISPLAY_READ |
+        gpu::SHARED_IMAGE_USAGE_GLES2_READ |
+        gpu::SHARED_IMAGE_USAGE_GLES2_WRITE;
+
+    // Map the Vulkan swapchain format to the matching SharedImage format so
+    // the GPU process imports the DMA-BUF with the correct channel layout.
+    viz::SharedImageFormat si_format =
+        (swapchain_format_ == VK_FORMAT_B8G8R8A8_SRGB)
+            ? viz::SinglePlaneFormat::kBGRA_8888
+            : viz::SinglePlaneFormat::kRGBA_8888;
+
+    swapchain_images[i].shared_image = sii->CreateSharedImage(
+        {si_format, size, gfx::ColorSpace::CreateSRGB(), shared_image_usage,
+         "OpenXrVulkanBinding"},
+        std::move(gmb_handle));
+
+    if (!swapchain_images[i].shared_image) {
+      LOG(ERROR) << "CreateSharedImage failed for slot " << i;
+      DestroyIntermediateImages();
+      return;
+    }
+
+    swapchain_images[i].sync_token = sii->GenVerifiedSyncToken();
+  }
+}
+
+bool OpenXrGraphicsBindingVulkan::WaitOnFence(OpenXrCompositionLayer& layer,
+                                              gfx::GpuFence& gpu_fence) {
+  if (!has_external_semaphore_fd_) {
+    return true;  // Extension not available (e.g. SwiftShader).
+  }
+
+  // Extract the sync FD from the GpuFence. Peek() returns a non-owned FD.
+  const gfx::GpuFenceHandle& fence_handle = gpu_fence.GetGpuFenceHandle();
+  int fence_fd = fence_handle.Peek();
+  if (fence_fd < 0) {
+    return true;  // No valid FD — nothing to wait on.
+  }
+
+  auto pfn_create_semaphore = reinterpret_cast<PFN_vkCreateSemaphore>(
+      vk_get_device_proc_addr_(vk_device_, "vkCreateSemaphore"));
+  auto pfn_import_semaphore_fd =
+      reinterpret_cast<PFN_vkImportSemaphoreFdKHR>(
+          vk_get_device_proc_addr_(vk_device_, "vkImportSemaphoreFdKHR"));
+  auto pfn_destroy_semaphore = reinterpret_cast<PFN_vkDestroySemaphore>(
+      vk_get_device_proc_addr_(vk_device_, "vkDestroySemaphore"));
+  auto pfn_queue_submit = reinterpret_cast<PFN_vkQueueSubmit>(
+      vk_get_device_proc_addr_(vk_device_, "vkQueueSubmit"));
+  auto pfn_reset_fences = reinterpret_cast<PFN_vkResetFences>(
+      vk_get_device_proc_addr_(vk_device_, "vkResetFences"));
+  auto pfn_wait_for_fences = reinterpret_cast<PFN_vkWaitForFences>(
+      vk_get_device_proc_addr_(vk_device_, "vkWaitForFences"));
+
+  if (!pfn_create_semaphore || !pfn_import_semaphore_fd ||
+      !pfn_destroy_semaphore || !pfn_queue_submit || !pfn_reset_fences ||
+      !pfn_wait_for_fences) {
+    LOG(ERROR) << "WaitOnFence: Failed to resolve Vulkan semaphore functions";
+    return false;
+  }
+
+  VkSemaphore semaphore = VK_NULL_HANDLE;
+  VkSemaphoreCreateInfo sem_ci{VK_STRUCTURE_TYPE_SEMAPHORE_CREATE_INFO};
+  if (pfn_create_semaphore(vk_device_, &sem_ci, nullptr, &semaphore) !=
+      VK_SUCCESS) {
+    LOG(ERROR) << "WaitOnFence: vkCreateSemaphore failed";
+    return false;
+  }
+
+  // Import the fence FD into the semaphore. vkImportSemaphoreFdKHR takes
+  // ownership of the FD on success, so we dup() since GpuFenceHandle still
+  // owns the original.
+  VkImportSemaphoreFdInfoKHR import_info{
+      VK_STRUCTURE_TYPE_IMPORT_SEMAPHORE_FD_INFO_KHR};
+  import_info.semaphore = semaphore;
+  import_info.flags = VK_SEMAPHORE_IMPORT_TEMPORARY_BIT;
+  import_info.handleType = VK_EXTERNAL_SEMAPHORE_HANDLE_TYPE_SYNC_FD_BIT;
+  import_info.fd = dup(fence_fd);
+
+  if (pfn_import_semaphore_fd(vk_device_, &import_info) != VK_SUCCESS) {
+    close(import_info.fd);
+    pfn_destroy_semaphore(vk_device_, semaphore, nullptr);
+    LOG(ERROR) << "WaitOnFence: vkImportSemaphoreFdKHR failed";
+    return false;
+  }
+
+  // Submit a wait on the imported semaphore so that subsequent GPU work
+  // (the blit in RenderLayer) does not start until the fence signals.
+  VkPipelineStageFlags wait_stage = VK_PIPELINE_STAGE_TRANSFER_BIT;
+  VkSubmitInfo submit{VK_STRUCTURE_TYPE_SUBMIT_INFO};
+  submit.waitSemaphoreCount = 1;
+  submit.pWaitSemaphores = &semaphore;
+  submit.pWaitDstStageMask = &wait_stage;
+
+  // Reset and use vk_frame_fence_ instead of vkQueueWaitIdle, scoping the
+  // CPU stall to this specific submit rather than all pending queue work.
+  pfn_reset_fences(vk_device_, 1, &vk_frame_fence_);
+  VkResult result = pfn_queue_submit(vk_queue_, 1, &submit, vk_frame_fence_);
+  if (result == VK_SUCCESS) {
+    pfn_wait_for_fences(vk_device_, 1, &vk_frame_fence_, VK_TRUE, UINT64_MAX);
+  }
+
+  pfn_destroy_semaphore(vk_device_, semaphore, nullptr);
+  return result == VK_SUCCESS;
+}
+
+bool OpenXrGraphicsBindingVulkan::RenderLayer(
+    OpenXrCompositionLayer& layer,
+    const scoped_refptr<viz::ContextProvider>& context_provider) {
+  if (!has_external_memory_fd_ || intermediate_images_.empty()) {
+    return true;  // No intermediate images — nothing to blit.
+  }
+
+  // Determine the active swapchain image and its index.
+  OpenXrSwapchainInfo* active_info = layer.GetActiveSwapchainImage();
+  if (!active_info) {
+    return false;
+  }
+
+  // Compute the index of the active image within the swapchain images span.
+  base::span<OpenXrSwapchainInfo> swapchain_images = layer.GetSwapchainImages();
+  size_t active_index = static_cast<size_t>(active_info - swapchain_images.data());
+  if (active_index >= intermediate_images_.size()) {
+    return false;
+  }
+
+  VkImage src = intermediate_images_[active_index].image;
+  VkImage dst = active_info->vk_image;
+  if (src == VK_NULL_HANDLE || dst == VK_NULL_HANDLE) {
+    return false;
+  }
+
+  const gfx::Size size = layer.GetSwapchainImageSize();
+
+  // Resolve device-level Vulkan function pointers.
+  auto pfn_reset_cb = reinterpret_cast<PFN_vkResetCommandBuffer>(
+      vk_get_device_proc_addr_(vk_device_, "vkResetCommandBuffer"));
+  auto pfn_begin_cb = reinterpret_cast<PFN_vkBeginCommandBuffer>(
+      vk_get_device_proc_addr_(vk_device_, "vkBeginCommandBuffer"));
+  auto pfn_end_cb = reinterpret_cast<PFN_vkEndCommandBuffer>(
+      vk_get_device_proc_addr_(vk_device_, "vkEndCommandBuffer"));
+  auto pfn_cmd_pipeline_barrier = reinterpret_cast<PFN_vkCmdPipelineBarrier>(
+      vk_get_device_proc_addr_(vk_device_, "vkCmdPipelineBarrier"));
+  auto pfn_cmd_copy_image = reinterpret_cast<PFN_vkCmdCopyImage>(
+      vk_get_device_proc_addr_(vk_device_, "vkCmdCopyImage"));
+  auto pfn_queue_submit = reinterpret_cast<PFN_vkQueueSubmit>(
+      vk_get_device_proc_addr_(vk_device_, "vkQueueSubmit"));
+  auto pfn_reset_fences = reinterpret_cast<PFN_vkResetFences>(
+      vk_get_device_proc_addr_(vk_device_, "vkResetFences"));
+  auto pfn_wait_for_fences = reinterpret_cast<PFN_vkWaitForFences>(
+      vk_get_device_proc_addr_(vk_device_, "vkWaitForFences"));
+
+  if (!pfn_reset_cb || !pfn_begin_cb || !pfn_end_cb ||
+      !pfn_cmd_pipeline_barrier || !pfn_cmd_copy_image || !pfn_queue_submit ||
+      !pfn_reset_fences || !pfn_wait_for_fences) {
+    LOG(ERROR) << "RenderLayer: Failed to resolve Vulkan command functions";
+    return false;
+  }
+
+  pfn_reset_cb(vk_command_buffer_, 0);
+
+  VkCommandBufferBeginInfo begin_info{
+      VK_STRUCTURE_TYPE_COMMAND_BUFFER_BEGIN_INFO};
+  begin_info.flags = VK_COMMAND_BUFFER_USAGE_ONE_TIME_SUBMIT_BIT;
+  if (pfn_begin_cb(vk_command_buffer_, &begin_info) != VK_SUCCESS) {
+    return false;
+  }
+
+  // Transition src from its tracked layout to TRANSFER_SRC_OPTIMAL.
+  // On first use the layout is UNDEFINED; on subsequent frames it is GENERAL
+  // (restored after the previous blit to allow external GL/DMA-BUF access).
+  // srcAccessMask=0 is correct because WaitOnFence already serialized the
+  // external GL writes via a semaphore wait on this queue.
+  VkImageMemoryBarrier src_barrier{VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER};
+  src_barrier.srcAccessMask = 0;
+  src_barrier.dstAccessMask = VK_ACCESS_TRANSFER_READ_BIT;
+  src_barrier.oldLayout = intermediate_images_[active_index].current_layout;
+  src_barrier.newLayout = VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL;
+  src_barrier.srcQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+  src_barrier.dstQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+  src_barrier.image = src;
+  src_barrier.subresourceRange = {VK_IMAGE_ASPECT_COLOR_BIT, 0, 1, 0, 1};
+  pfn_cmd_pipeline_barrier(
+      vk_command_buffer_, VK_PIPELINE_STAGE_TOP_OF_PIPE_BIT,
+      VK_PIPELINE_STAGE_TRANSFER_BIT, 0, 0, nullptr, 0, nullptr, 1,
+      &src_barrier);
+
+  // Transition dst: UNDEFINED -> TRANSFER_DST_OPTIMAL.
+  // OpenXR swapchain images start in UNDEFINED or COLOR_ATTACHMENT_OPTIMAL
+  // after xrAcquireSwapchainImage. Using UNDEFINED as oldLayout is always safe.
+  VkImageMemoryBarrier dst_barrier{VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER};
+  dst_barrier.srcAccessMask = 0;
+  dst_barrier.dstAccessMask = VK_ACCESS_TRANSFER_WRITE_BIT;
+  dst_barrier.oldLayout = VK_IMAGE_LAYOUT_UNDEFINED;
+  dst_barrier.newLayout = VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL;
+  dst_barrier.srcQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+  dst_barrier.dstQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+  dst_barrier.image = dst;
+  dst_barrier.subresourceRange = {VK_IMAGE_ASPECT_COLOR_BIT, 0, 1, 0, 1};
+  pfn_cmd_pipeline_barrier(vk_command_buffer_, VK_PIPELINE_STAGE_TOP_OF_PIPE_BIT,
+                           VK_PIPELINE_STAGE_TRANSFER_BIT, 0, 0, nullptr, 0,
+                           nullptr, 1, &dst_barrier);
+
+  // Copy the intermediate image to the swapchain image.
+  VkImageCopy region{};
+  region.srcSubresource = {VK_IMAGE_ASPECT_COLOR_BIT, 0, 0, 1};
+  region.dstSubresource = {VK_IMAGE_ASPECT_COLOR_BIT, 0, 0, 1};
+  region.extent = {static_cast<uint32_t>(size.width()),
+                   static_cast<uint32_t>(size.height()), 1};
+  pfn_cmd_copy_image(vk_command_buffer_, src,
+                     VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL, dst,
+                     VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, 1, &region);
+
+  // Composite the browser overlay (permission prompts, capture indicators,
+  // etc.) on top of the WebXR content. dst is already in TRANSFER_DST_OPTIMAL.
+  // The overlay is blitted to a fixed screen-space rect per eye.
+  if (overlay_visible_ && has_overlay_) {
+    RecordOverlayBlitCommands(vk_command_buffer_, dst, size);
+  }
+
+  // Transition dst back: TRANSFER_DST_OPTIMAL -> COLOR_ATTACHMENT_OPTIMAL.
+  // OpenXR expects COLOR_ATTACHMENT_OPTIMAL for xrReleaseSwapchainImage.
+  dst_barrier.srcAccessMask = VK_ACCESS_TRANSFER_WRITE_BIT;
+  dst_barrier.dstAccessMask = VK_ACCESS_COLOR_ATTACHMENT_READ_BIT;
+  dst_barrier.oldLayout = VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL;
+  dst_barrier.newLayout = VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL;
+  pfn_cmd_pipeline_barrier(vk_command_buffer_, VK_PIPELINE_STAGE_TRANSFER_BIT,
+                           VK_PIPELINE_STAGE_COLOR_ATTACHMENT_OUTPUT_BIT, 0, 0,
+                           nullptr, 0, nullptr, 1, &dst_barrier);
+
+  // Transition src back to GENERAL so the next GL/DMA-BUF write has a
+  // well-defined Vulkan layout on the subsequent frame.
+  src_barrier.srcAccessMask = VK_ACCESS_TRANSFER_READ_BIT;
+  src_barrier.dstAccessMask = 0;
+  src_barrier.oldLayout = VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL;
+  src_barrier.newLayout = VK_IMAGE_LAYOUT_GENERAL;
+  pfn_cmd_pipeline_barrier(vk_command_buffer_, VK_PIPELINE_STAGE_TRANSFER_BIT,
+                           VK_PIPELINE_STAGE_BOTTOM_OF_PIPE_BIT, 0, 0, nullptr,
+                           0, nullptr, 1, &src_barrier);
+
+  if (pfn_end_cb(vk_command_buffer_) != VK_SUCCESS) {
+    return false;
+  }
+
+  // Submit with vk_frame_fence_ instead of vkQueueWaitIdle, scoping the CPU
+  // stall to this specific submit.
+  VkSubmitInfo submit{VK_STRUCTURE_TYPE_SUBMIT_INFO};
+  submit.commandBufferCount = 1;
+  submit.pCommandBuffers = &vk_command_buffer_;
+  pfn_reset_fences(vk_device_, 1, &vk_frame_fence_);
+  VkResult result = pfn_queue_submit(vk_queue_, 1, &submit, vk_frame_fence_);
+  if (result != VK_SUCCESS) {
+    return false;
+  }
+  pfn_wait_for_fences(vk_device_, 1, &vk_frame_fence_, VK_TRUE, UINT64_MAX);
+
+  // Record the new layout for next frame's barrier.
+  intermediate_images_[active_index].current_layout = VK_IMAGE_LAYOUT_GENERAL;
+  return true;
+}
+
+void OpenXrGraphicsBindingVulkan::CleanupWithoutSubmit() {
+  DestroyIntermediateImages();
+}
