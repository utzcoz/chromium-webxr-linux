+
+void OpenXrGraphicsBindingVulkan::RecordOverlayBlitCommands(
+    VkCommandBuffer cb,
+    VkImage dst,
+    const gfx::Size& swapchain_size) {
+  CHECK(has_overlay_);
+  CHECK(overlay_image_ != VK_NULL_HANDLE);
+  CHECK(vk_get_device_proc_addr_);
+
+  auto pfn_cmd_pipeline_barrier = reinterpret_cast<PFN_vkCmdPipelineBarrier>(
+      vk_get_device_proc_addr_(vk_device_, "vkCmdPipelineBarrier"));
+  auto pfn_cmd_blit_image = reinterpret_cast<PFN_vkCmdBlitImage>(
+      vk_get_device_proc_addr_(vk_device_, "vkCmdBlitImage"));
+  if (!pfn_cmd_pipeline_barrier || !pfn_cmd_blit_image) {
+    DVLOG(1) << "RecordOverlayBlitCommands: function pointers unavailable";
+    return;
+  }
+
+  // Transition overlay from its tracked layout to TRANSFER_SRC_OPTIMAL.
+  VkImageMemoryBarrier ov_barrier{VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER};
+  ov_barrier.srcAccessMask = 0;
+  ov_barrier.dstAccessMask = VK_ACCESS_TRANSFER_READ_BIT;
+  ov_barrier.oldLayout = overlay_layout_;
+  ov_barrier.newLayout = VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL;
+  ov_barrier.srcQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+  ov_barrier.dstQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+  ov_barrier.image = overlay_image_;
+  ov_barrier.subresourceRange = {VK_IMAGE_ASPECT_COLOR_BIT, 0, 1, 0, 1};
+  pfn_cmd_pipeline_barrier(cb, VK_PIPELINE_STAGE_TOP_OF_PIPE_BIT,
+                           VK_PIPELINE_STAGE_TRANSFER_BIT, 0, 0, nullptr, 0,
+                           nullptr, 1, &ov_barrier);
+
+  // Destination rectangle: center-bottom 30% of each eye half of the
+  // swapchain. Not head-locked to world space — this is a screen-space
+  // overlay, so the dialog always stays in the user's view. A full quad-
+  // layer implementation (with proper 3D pose) is a follow-up.
+  const int sw = swapchain_size.width();
+  const int sh = swapchain_size.height();
+  const int eye_w = sw / 2;
+  const int dst_w = eye_w * 40 / 100;   // 40% of eye width
+  const int dst_h = sh * 25 / 100;      // 25% of full height
+  const int dst_y = sh * 60 / 100;      // centered-low
+  const int left_dst_x = (eye_w - dst_w) / 2;
+  const int right_dst_x = eye_w + (eye_w - dst_w) / 2;
+
+  auto uv_to_src_offset = [&](const gfx::RectF& uv, bool right_edge) {
+    const int x =
+        static_cast<int>((right_edge ? uv.right() : uv.x()) * overlay_size_.width());
+    const int y =
+        static_cast<int>((right_edge ? uv.bottom() : uv.y()) * overlay_size_.height());
+    return VkOffset3D{x, y, right_edge ? 1 : 0};
+  };
+
+  VkImageBlit blits[2];
+  // Left eye.
+  blits[0].srcSubresource = {VK_IMAGE_ASPECT_COLOR_BIT, 0, 0, 1};
+  blits[0].dstSubresource = {VK_IMAGE_ASPECT_COLOR_BIT, 0, 0, 1};
+  blits[0].srcOffsets[0] = uv_to_src_offset(overlay_left_uv_, false);
+  blits[0].srcOffsets[1] = uv_to_src_offset(overlay_left_uv_, true);
+  blits[0].dstOffsets[0] = {left_dst_x, dst_y, 0};
+  blits[0].dstOffsets[1] = {left_dst_x + dst_w, dst_y + dst_h, 1};
+  // Right eye.
+  blits[1].srcSubresource = {VK_IMAGE_ASPECT_COLOR_BIT, 0, 0, 1};
+  blits[1].dstSubresource = {VK_IMAGE_ASPECT_COLOR_BIT, 0, 0, 1};
+  blits[1].srcOffsets[0] = uv_to_src_offset(overlay_right_uv_, false);
+  blits[1].srcOffsets[1] = uv_to_src_offset(overlay_right_uv_, true);
+  blits[1].dstOffsets[0] = {right_dst_x, dst_y, 0};
+  blits[1].dstOffsets[1] = {right_dst_x + dst_w, dst_y + dst_h, 1};
+
+  pfn_cmd_blit_image(cb, overlay_image_, VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL,
+                     dst, VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, 2, blits,
+                     VK_FILTER_LINEAR);
+
+  // Restore overlay to GENERAL so the next browser-side write doesn't see
+  // TRANSFER_SRC.
+  ov_barrier.srcAccessMask = VK_ACCESS_TRANSFER_READ_BIT;
+  ov_barrier.dstAccessMask = 0;
+  ov_barrier.oldLayout = VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL;
+  ov_barrier.newLayout = VK_IMAGE_LAYOUT_GENERAL;
+  pfn_cmd_pipeline_barrier(cb, VK_PIPELINE_STAGE_TRANSFER_BIT,
+                           VK_PIPELINE_STAGE_BOTTOM_OF_PIPE_BIT, 0, 0,
+                           nullptr, 0, nullptr, 1, &ov_barrier);
+  overlay_layout_ = VK_IMAGE_LAYOUT_GENERAL;
+}
+
+bool OpenXrGraphicsBindingVulkan::SetOverlayTexture(
+    gfx::GpuMemoryBufferHandle texture,
+    const gpu::SyncToken& sync_token,
+    const gfx::RectF& left,
+    const gfx::RectF& right) {
+  if (texture.is_null()) {
+    // Browser signals "no overlay this frame" by sending a null handle.
+    // Retain the imported VkImage so we can keep compositing with the same
+    // GPU resources next frame; just mark the overlay as inactive.
+    has_overlay_ = false;
+    return true;
+  }
+
+  if (!has_external_memory_fd_) {
+    DVLOG(1) << "SetOverlayTexture: VK_KHR_external_memory_fd unavailable, "
+             << "overlay will not be composited";
+    has_overlay_ = false;
+    return true;
+  }
+
+  // Derive the logical pixel size from the NativePixmapHandle's first plane.
+  // The browser-side GraphicsDelegate exports an RGBA_8888 SharedImage via
+  // gfx::BufferUsage::SCANOUT, so the per-eye-pair stereo texture is
+  // (left_viewport + right_viewport) wide.
+  if (texture.type != gfx::NATIVE_PIXMAP) {
+    LOG(ERROR) << "SetOverlayTexture: expected NATIVE_PIXMAP, got "
+               << static_cast<int>(texture.type);
+    return false;
+  }
+  const gfx::NativePixmapHandle& pixmap = texture.native_pixmap_handle();
+  if (pixmap.planes.empty()) {
+    LOG(ERROR) << "SetOverlayTexture: no planes in NativePixmapHandle";
+    return false;
+  }
+
+  // The SharedImage size travels alongside the handle on the browser side;
+  // the Chromium utility process recovers it from the SharedImage service.
+  // Here we approximate it from the plane stride (bytes/row / 4) × height
+  // inferred from allocation size when the handle doesn't carry size
+  // directly. To keep this simple and correct, we assume the overlay size
+  // matches the latest `left.union(right)` normalized bounds scaled to the
+  // intermediate image size — which is exactly the browser-side texture.
+  gfx::Size size;
+  if (!intermediate_images_.empty()) {
+    // The overlay matches GraphicsDelegate::GetTextureSize() which is the
+    // same size as our intermediate (swapchain) images.
+    // Re-query the current swapchain image size from the first intermediate.
+    // The browser-side texture width = left_viewport + right_viewport, same
+    // as our swapchain image.
+    // Fallback: use 2 × max-texture for safety if the query fails.
+    // We'll trust the GpuMemoryBuffer stride + height to derive the size.
+    uint32_t stride = pixmap.planes[0].stride;
+    uint32_t width = stride / 4;  // RGBA8 = 4 bytes/texel
+    uint64_t plane_size = pixmap.planes[0].size;
+    uint32_t height = width ? static_cast<uint32_t>(plane_size / stride) : 0;
+    if (width == 0 || height == 0) {
+      LOG(ERROR) << "SetOverlayTexture: cannot derive overlay size "
+                 << "(stride=" << stride << ", size=" << plane_size << ")";
+      return false;
+    }
+    size = gfx::Size(width, height);
+  } else {
+    LOG(ERROR) << "SetOverlayTexture: called before intermediate images were "
+               << "created";
+    return false;
+  }
+
+  // Re-import only when the size changed; otherwise reuse the existing
+  // VkImage. Note that a new DMA-BUF FD is sent every frame, but as long as
+  // the underlying SharedImage is the same size, the ID3D11-equivalent
+  // binding on Linux is to keep the same VkImage tied to the same memory.
+  // In practice the browser-side GraphicsDelegate::EnsureMemoryBuffer()
+  // recreates the SharedImage only on resize, so we mirror that policy here.
+  if (overlay_image_ == VK_NULL_HANDLE || size != overlay_size_) {
+    DestroyOverlayImage();
+    // GraphicsDelegate uses kRGBA_8888 (non-SRGB); match with UNORM so the
+    // copy preserves the already-gamma-encoded browser UI pixels.
+    if (!ImportOverlayDmaBuf(texture, size, VK_FORMAT_R8G8B8A8_UNORM)) {
+      has_overlay_ = false;
+      return false;
+    }
+  }
+
+  overlay_left_uv_ = left;
+  overlay_right_uv_ = right;
+  has_overlay_ = true;
+  return true;
+}
