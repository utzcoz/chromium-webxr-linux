+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+// Linux-specific implementations of static methods on OpenXrPlatformHelper
+// and OpenXrGraphicsBinding that are called during xrCreateInstance.
+// Mirrors device/vr/openxr/android/openxr_platform_helper_android_statics.cc.
+
+#include "device/vr/openxr/openxr_graphics_binding.h"
+#include "device/vr/openxr/openxr_platform_helper.h"
+
+namespace device {
+
+// static
+void OpenXrPlatformHelper::GetRequiredExtensions(
+    std::vector<const char*>& extensions) {
+  // Linux has no platform-specific required extensions for xrCreateInstance.
+  // (Android requires XR_KHR_android_create_instance here; Windows
+  // conditionally requires XR_EXT_win32_appcontainer_compatible.)
+}
+
+// static
+std::vector<const char*> OpenXrPlatformHelper::GetOptionalExtensions() {
+  // No Linux-specific optional platform extensions.
+  return {};
+}
+
+// static
+void OpenXrGraphicsBinding::GetRequiredExtensions(
+    std::vector<const char*>& extensions) {
+  extensions.push_back("XR_KHR_vulkan_enable2");
+}
+
+}  // namespace device
