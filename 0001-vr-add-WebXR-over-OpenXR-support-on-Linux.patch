diff --git a/chrome/browser/vr/chrome_xr_integration_client.cc b/chrome/browser/vr/chrome_xr_integration_client.cc
index 889bf77106d53..79bacede54d2e 100644
--- a/chrome/browser/vr/chrome_xr_integration_client.cc
+++ b/chrome/browser/vr/chrome_xr_integration_client.cc
@@ -189,7 +189,21 @@ std::unique_ptr<content::VrUiHost> ChromeXrIntegrationClient::CreateVrUiHost(
     content::WebContents& contents,
     const std::vector<device::mojom::XRViewPtr>& views,
     mojo::PendingRemote<device::mojom::ImmersiveOverlay> overlay) {
+#if BUILDFLAG(IS_LINUX)
+  // VRUiHostImpl walks into chrome/browser/vr/ui.cc shader compilation that
+  // relies on gles2_lib's thread-local GL context. gles2::Initialize() —
+  // which allocates that TLS key — is only called from tests, so the
+  // browser-process path crashes with a null-dereference on the first
+  // glCreateShader during session startup. Returning nullptr here keeps
+  // the WebXR session running without the overlay; the utility-process
+  // Vulkan-side overlay plumbing (SetOverlayTexture, vkCmdBlitImage
+  // composite) is left in place so a future browser-side fix can flip
+  // this switch without further work.
+  // TODO(crbug): wire the browser-process GLES2 TLS lifecycle for Linux.
+  return nullptr;
+#else
   return std::make_unique<VRUiHostImpl>(contents, views, std::move(overlay));
+#endif
 }
 }  // namespace vr
 
