@@ -25,16 +26,28 @@ void GraphicsDelegateWin::Initialize(base::OnceClosure on_initialized) {
   gpu::GpuChannelEstablishFactory* factory =
       content::GetGpuChannelEstablishFactory();
   gpu_channel_host_ = factory->EstablishGpuChannelSync();
+  if (!gpu_channel_host_) {
+    LOG(ERROR) << __func__ << ": EstablishGpuChannelSync returned null; "
+               << "overlay UI cannot render.";
+    std::move(on_initialized).Run();
+    return;
+  }
 
   context_provider_ = viz::ContextProviderCommandBuffer::CreateForGL(
       gpu_channel_host_, content::kGpuStreamIdDefault,
       content::kGpuStreamPriorityUI, GURL("chrome://gpu/VrUiWin"),
       viz::command_buffer_metrics::ContextType::XR_COMPOSITING);
 
-  if (context_provider_->BindToCurrentSequence() ==
-      gpu::ContextResult::kSuccess) {
+  gpu::ContextResult result = context_provider_->BindToCurrentSequence();
+  if (result == gpu::ContextResult::kSuccess) {
     gl_ = context_provider_->ContextGL();
     sii_ = context_provider_->SharedImageInterface();
+  } else {
+    LOG(ERROR) << __func__
+               << ": ContextProviderCommandBuffer::BindToCurrentSequence "
+                  "failed, result="
+               << static_cast<int>(result)
+               << "; overlay UI cannot render.";
   }
 
   std::move(on_initialized).Run();
diff --git a/chrome/browser/vr/vr_browser_renderer_thread.cc b/chrome/browser/vr/vr_browser_renderer_thread.cc
index e42e1101f36f2..2ba266f41cfeb 100644
--- a/chrome/browser/vr/vr_browser_renderer_thread.cc
+++ b/chrome/browser/vr/vr_browser_renderer_thread.cc
@@ -289,7 +289,18 @@ void VRBrowserRendererThread::OnGraphicsReady(
   DCHECK(!default_views_.empty());
   graphics_->SetXrViews(default_views_);
 
-  graphics_->BindContext();
+  // BindContext sets the thread-local GL context used by subsequent shader
+  // compilation in Ui::OnGlInitialized. If it fails (e.g. GPU-channel
+  // establishment returned no ContextGL), calling into the UI renderer will
+  // dereference a null TLS context and crash. Bail early instead; the
+  // overlay will simply not render this session.
+  if (!graphics_->BindContext()) {
+    LOG(ERROR) << __func__
+               << ": GraphicsDelegate::BindContext() failed; skipping VR "
+                  "browser overlay for this session.";
+    graphics_ = nullptr;
+    return;
+  }
 
   // Create a vr::Ui
   std::unique_ptr<Ui> ui = std::make_unique<Ui>();
