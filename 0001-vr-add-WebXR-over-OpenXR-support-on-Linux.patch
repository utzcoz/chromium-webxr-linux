+std::unique_ptr<OpenXrCompositionLayer::GraphicsBindingData>
+OpenXrGraphicsBindingVulkan::CreateLayerGraphicsBindingData() const {
+  // No per-layer Vulkan state needed for the single-layer MVP.
+  return nullptr;
+}
