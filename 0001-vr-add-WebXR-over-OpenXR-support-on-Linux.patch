@@ -56,6 +56,7 @@ using XrRuntimeManagerObservers =
 namespace {
 XRRuntimeManagerImpl* g_xr_runtime_manager = nullptr;
 
+
 XrRuntimeManagerObservers& GetXrRuntimeManagerObservers() {
   static base::NoDestructor<XrRuntimeManagerObservers>
       xr_runtime_manager_observers;
@@ -201,7 +202,21 @@ XRRuntimeManagerImpl::GetOrCreateRuntimeManagerInternal(
         std::make_unique<device::VROrientationDeviceProvider>(
             std::move(sensor_provider)));
   }
-  return CreateInstance(std::move(providers), web_contents);
+  auto instance = CreateInstance(std::move(providers), web_contents);
+
+#if BUILDFLAG(IS_LINUX)
+  // Keep the manager alive across page navigations so the utility process
+  // and its cached XrInstance are not torn down on navigation. Without this,
+  // the ~5-second re-enumeration gap causes isSessionSupported to return false.
+  // base::NoDestructor<scoped_refptr<>> is the Chromium-idiomatic way to hold
+  // an intentional leak without triggering exit-time destructor warnings.
+  // TODO(crbug.com/397907158): Remove once async session cleanup is fixed.
+  static base::NoDestructor<scoped_refptr<XRRuntimeManagerImpl>>
+      g_linux_persistent_ref;
+  *g_linux_persistent_ref = instance;
+#endif
+
+  return instance;
 }
 
 scoped_refptr<XRRuntimeManagerImpl> XRRuntimeManagerImpl::GetOrCreateInstance(
