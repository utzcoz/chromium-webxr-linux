diff --git a/device/vr/public/cpp/switches.h b/device/vr/public/cpp/switches.h
index b9bde0c828f85..04561860f356f 100644
--- a/device/vr/public/cpp/switches.h
+++ b/device/vr/public/cpp/switches.h
@@ -16,6 +16,18 @@ COMPONENT_EXPORT(VR_FEATURES)
 extern const char kWebXrHandAnonymizationStrategyRuntime[];
 COMPONENT_EXPORT(VR_FEATURES)
