 #include <string_view>
 #include <vector>
 
+#include "base/command_line.h"
 #include "base/compiler_specific.h"
 #include "base/files/scoped_file.h"
 #include "base/logging.h"
@@ -19,6 +20,7 @@
 #include "device/vr/openxr/openxr_extension_helper.h"
 #include "device/vr/openxr/openxr_swapchain_info.h"
 #include "device/vr/openxr/openxr_util.h"
+#include "device/vr/public/cpp/switches.h"
 #include "gpu/command_buffer/client/client_shared_image.h"
 #include "gpu/command_buffer/client/shared_image_interface.h"
 #include "gpu/command_buffer/common/shared_image_usage.h"
@@ -428,28 +430,44 @@ int64_t OpenXrGraphicsBindingVulkan::GetSwapchainFormat(
     return 0;
   }
 
-  // Prefer SRGB formats for correct color rendering. Try RGBA first (matches
-  // the SharedImage default), fall back to BGRA, otherwise accept formats[0].
+  // Choose a channel ordering. The default prefers RGBA (matches the
+  // SharedImage default); --webxr-openxr-swapchain-format=bgra prefers BGRA for
+  // configs whose GL/compositor path expects BGRA channel order. Within each
+  // ordering, SRGB is preferred over UNORM for correct color. The non-preferred
+  // ordering is kept as a fallback so a runtime that only advertises one
+  // ordering still works, and formats[0] is the last resort.
+  const bool prefer_bgra =
+      base::CommandLine::ForCurrentProcess()->GetSwitchValueASCII(
+          switches::kWebXrOpenXrSwapchainFormat) ==
+      switches::kWebXrOpenXrSwapchainFormatBgra;
+
+  const int64_t kPreferRgba[] = {
+      VK_FORMAT_R8G8B8A8_SRGB, VK_FORMAT_R8G8B8A8_UNORM,
+      VK_FORMAT_B8G8R8A8_SRGB, VK_FORMAT_B8G8R8A8_UNORM};
+  const int64_t kPreferBgra[] = {
+      VK_FORMAT_B8G8R8A8_SRGB, VK_FORMAT_B8G8R8A8_UNORM,
+      VK_FORMAT_R8G8B8A8_SRGB, VK_FORMAT_R8G8B8A8_UNORM};
+  const auto& preference = prefer_bgra ? kPreferBgra : kPreferRgba;
+
   int64_t selected = formats[0];
-  bool found = false;
-  for (int64_t f : formats) {
-    if (f == VK_FORMAT_R8G8B8A8_SRGB) {
-      selected = f;
-      found = true;
-      break;
-    }
-  }
-  if (!found) {
+  for (int64_t candidate : preference) {
+    bool offered = false;
     for (int64_t f : formats) {
-      if (f == VK_FORMAT_B8G8R8A8_SRGB) {
-        selected = f;
+      if (f == candidate) {
+        offered = true;
         break;
       }
     }
+    if (offered) {
+      selected = candidate;
+      break;
+    }
   }
   // Cache the negotiated format so CreateSharedImages() can create matching
   // intermediate images without needing to re-query the session.
   swapchain_format_ = static_cast<VkFormat>(selected);
+  VLOG(1) << "OpenXR Vulkan swapchain format negotiated: " << selected
+          << (prefer_bgra ? " (bgra requested)" : " (rgba/default)");
   return selected;
 }
 
@@ -920,17 +938,22 @@ void OpenXrGraphicsBindingVulkan::CreateSharedImages(
 
     // The SharedImages created here will be transferred to other processes to
     // have their contents written by WebGL or WebGPU. Readback by OpenXR is
-    // via the blit in RenderLayer.
+    // via the blit in RenderLayer. NOTE: no SHARED_IMAGE_USAGE_SCANOUT — these
+    // images are blitted into the OpenXR swapchain, never scanned out to a
+    // display. Requesting SCANOUT on a LINEAR (modifier 0) NativePixmap leaves
+    // no backing factory able to satisfy it, so CreateSharedImage returns null.
     gpu::SharedImageUsageSet shared_image_usage =
-        gpu::SHARED_IMAGE_USAGE_SCANOUT |
         gpu::SHARED_IMAGE_USAGE_DISPLAY_READ |
         gpu::SHARED_IMAGE_USAGE_GLES2_READ |
         gpu::SHARED_IMAGE_USAGE_GLES2_WRITE;
 
     // Map the Vulkan swapchain format to the matching SharedImage format so
     // the GPU process imports the DMA-BUF with the correct channel layout.
+    // Match the SharedImage channel order to the negotiated swapchain format so
+    // colors are not swizzled. Both SRGB and UNORM BGRA map to kBGRA_8888.
     viz::SharedImageFormat si_format =
-        (swapchain_format_ == VK_FORMAT_B8G8R8A8_SRGB)
+        (swapchain_format_ == VK_FORMAT_B8G8R8A8_SRGB ||
+         swapchain_format_ == VK_FORMAT_B8G8R8A8_UNORM)
             ? viz::SinglePlaneFormat::kBGRA_8888
             : viz::SinglePlaneFormat::kRGBA_8888;
 
