+
+// Selects the swapchain pixel format the Linux OpenXR/Vulkan backend negotiates
+// in OpenXrGraphicsBindingVulkan::GetSwapchainFormat(). Accepts the values
+// below; absent or unrecognized values keep the default (RGBA) behavior.
+COMPONENT_EXPORT(VR_FEATURES)
+extern const char kWebXrOpenXrSwapchainFormat[];
+// "rgba": prefer VK_FORMAT_R8G8B8A8_SRGB (default).
+COMPONENT_EXPORT(VR_FEATURES)
+extern const char kWebXrOpenXrSwapchainFormatRgba[];
+// "bgra": prefer VK_FORMAT_B8G8R8A8_SRGB (falls back to *_UNORM).
+COMPONENT_EXPORT(VR_FEATURES)
+extern const char kWebXrOpenXrSwapchainFormatBgra[];
 }  // namespace device::switches
 
 #endif  // DEVICE_VR_PUBLIC_CPP_SWITCHES_H_
